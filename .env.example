# ══════════════════════════════════════════════════════════════════════════════
# JobFinder — variables d'environnement
# Copier en .env (dev local) ou définir dans Railway → Variables (prod)
# ══════════════════════════════════════════════════════════════════════════════

# ── OBLIGATOIRES en prod ──────────────────────────────────────────────────────
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_cette_valeur_par_une_cle_aleatoire_stable

# URL publique de l'app (pour les liens emails)
APP_URL=https://jobfinder-production.up.railway.app

# Email auto-promu admin lors de son inscription
ADMIN_EMAIL=

# ── Clé OpenAI partagée (utilisée par /api/fetch-url) ────────────────────────
# Optionnelle : si absente, la récupération d'URL d'offre est désactivée
OPENAI_API_KEY=sk-proj-VOTRE_CLE_ICI

# ── Chiffrement des clés API stockées en DB (Fernet) ────────────────────────
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Sans clé = clés API en clair en DB (déconseillé en prod)
FERNET_KEY=

# ── Email (SMTP) — pour vérification + reset password ────────────────────────
# Sans config SMTP : les emails sont LOGÉS en console (mode dev)
# Exemples :
#   Gmail   : SMTP_HOST=smtp.gmail.com SMTP_PORT=587 (mot de passe d'application requis)
#   Mailgun : SMTP_HOST=smtp.mailgun.org SMTP_PORT=587
#   SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Active la vérification d'email à l'inscription (par défaut: 1 si SMTP configuré)
REQUIRE_EMAIL_VERIFICATION=1

# ── hCaptcha (anti-bot register) ─────────────────────────────────────────────
# Compte gratuit : https://www.hcaptcha.com (récupère secret + site key)
# Sans config : pas de captcha (no-op)
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=

# ── Sentry (monitoring d'erreurs) ────────────────────────────────────────────
# Compte gratuit : https://sentry.io (récupère le DSN)
SENTRY_DSN=

# ── Quota mensuel par défaut (appels IA / user / mois) ───────────────────────
MONTHLY_AI_QUOTA=200

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ── Détection prod (auto via RAILWAY_ENVIRONMENT/DYNO) ──────────────────────
# FLASK_ENV=production
