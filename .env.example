# ══════════════════════════════════════════════════════════════════════════════
# JobFinder — variables d'environnement
# Copier en .env (pour dev local) ou définir dans Railway → Variables (en prod)
# ══════════════════════════════════════════════════════════════════════════════

# ── Clés API IA ───────────────────────────────────────────────────────────────
# Clé OpenAI partagée (utilisée par /api/fetch-url uniquement, le reste tape la
# clé du user). Optionnelle, mais sans elle la récupération d'URL est désactivée.
OPENAI_API_KEY=sk-proj-VOTRE_CLE_ICI

# ── Sécurité Flask ────────────────────────────────────────────────────────────
# OBLIGATOIRE en prod. Le serveur refuse de démarrer sans en prod.
# Génère-en une stable : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_cette_valeur_par_une_cle_aleatoire_stable

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email auto-promu admin lors de son inscription. Recommandé en prod.
# (En local, le 1er user inscrit est auto-admin si ADMIN_EMAIL est vide.)
ADMIN_EMAIL=

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ── Détection prod ────────────────────────────────────────────────────────────
# Mettre à "production" pour activer cookies Secure + SameSite=Strict + HSTS,
# en plus des variables auto-détectées (RAILWAY_ENVIRONMENT, DYNO).
# FLASK_ENV=production
