    <div class="wiz-foot" id="wiz-foot"></div>
  </div>
</div>

<!-- Admin -->
<div id="page-admin" class="page">
  <div class="ph">
    <div class="ph-text"><h2>🛡️ Administration</h2><p>Gestion des utilisateurs</p></div>
    <button class="btn btn-secondary btn-sm" onclick="loadAdminUsers()">🔄 Actualiser</button>
  </div>
  <div class="card">
    <div class="card-title">👥 Utilisateurs</div>
    <table class="admin-table" style="width:100%;border-collapse:collapse">
      <thead><tr style="border-bottom:1px solid var(--border)">
        <th style="text-align:left;padding:10px 14px;font-size:11px;color:var(--text3);text-transform:uppercase">Utilisateur</th>
        <th style="text-align:left;padding:10px 14px;font-size:11px;color:var(--text3);text-transform:uppercase">Email</th>
        <th style="text-align:left;padding:10px 14px;font-size:11px;color:var(--text3);text-transform:uppercase">Inscription</th>
        <th style="text-align:left;padding:10px 14px;font-size:11px;color:var(--text3);text-transform:uppercase">Rôle</th>
        <th style="padding:10px 14px"></th>
      </tr></thead>
      <tbody id="admin-users-tbody"></tbody>
    </table>
  </div>
</div>

</main>
</div>

<!-- Auth Overlay -->
<div id="auth-overlay">

  <!-- ══ LEFT — Marketing panel ══ -->
  <div class="auth-left">
    <div class="auth-dots"></div>

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-brand-icon">
        <svg viewBox="0 0 34 34" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
          <path d="M5 12Q5 9 8 9H26Q29 9 29 12V22Q29 25 26 25H19.5L17 29L14.5 25H8Q5 25 5 22Z" fill="rgba(255,255,255,.95)"/>
          <path d="M13 9V8Q13 7 14.5 7H19.5Q21 7 21 8V9" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round"/>
          <circle cx="17" cy="17" r="5.5" fill="#5BB98C"/>
          <circle cx="17" cy="17" r="3.2" fill="rgba(255,255,255,.95)"/>
          <circle cx="17" cy="17" r="1.3" fill="#5BB98C"/>
        </svg>
      </div>
      <h1>JobFinder</h1>
    </div>

    <!-- Headline -->
    <div class="auth-headline">
      <h2>Crée un CV parfait<br>pour chaque offre en<br><em>20 secondes.</em></h2>
      <p>L'offre d'emploi analyse et adapte ton CV automatiquement pour <strong style="color:rgba(255,255,255,.9)">maximiser tes chances</strong> d'être recruté.</p>
    </div>

    <!-- Flow illustration -->
    <div class="auth-flow">
      <div class="auth-flow-box">
        <div class="auth-flow-label">Offre d'emploi</div>
        <div class="auth-flow-lines">
          <div class="auth-flow-line"></div>
          <div class="auth-flow-line"></div>
          <div class="auth-flow-line"></div>
        </div>
      </div>
      <div class="auth-flow-arrow">→</div>
      <div class="auth-flow-orb">⚡</div>
      <div class="auth-flow-arrow">→</div>
      <div class="auth-flow-cv">
        <div class="auth-flow-cv-head">
          <div class="auth-flow-cv-avatar"></div>
          <div class="auth-flow-cv-ats">ATS</div>
        </div>
        <div class="auth-flow-cv-lines">
          <div class="auth-flow-cv-line"></div>
          <div class="auth-flow-cv-line"></div>
        </div>
        <div class="auth-flow-cv-check">✓ Prêt à postuler !</div>
      </div>
    </div>

    <!-- Stats with animated counters -->
    <div class="auth-stats" id="auth-stats">
      <div class="auth-stat" data-delay="0">
        <span class="auth-stat-icon">⚡</span>
        <div class="auth-stat-num">
          <span class="odo-wrap" data-target="20" data-suffix="s"></span>
        </div>
        <div class="auth-stat-label">CV optimisé</div>
      </div>
      <div class="auth-stat" data-delay="120">
        <span class="auth-stat-icon">📈</span>
        <div class="auth-stat-num">
          <span class="prefix">+</span><span class="odo-wrap" data-target="72" data-suffix="%"></span>
        </div>
        <div class="auth-stat-label">Plus d'entretiens</div>
      </div>
      <div class="auth-stat" data-delay="240">
        <span class="auth-stat-icon">🕐</span>
        <div class="auth-stat-num">
          <span class="odo-wrap" data-target="2" data-suffix="h"></span>
        </div>
        <div class="auth-stat-label">Gagnées par candidature</div>
      </div>
      <div class="auth-stat" data-delay="360">
        <span class="auth-stat-icon">🎯</span>
        <div class="auth-stat-num">
          <span class="odo-wrap" data-target="100" data-suffix="%"></span>
        </div>
        <div class="auth-stat-label">Adapté à l'offre et aux ATS</div>
      </div>
    </div>

    <!-- Social proof -->
    <div class="auth-social" id="auth-social">
      <div class="auth-social-avatars">
        <div class="auth-social-av" style="background:linear-gradient(135deg,#3a6cc0,#2F5DA8)">T</div>
        <div class="auth-social-av" style="background:linear-gradient(135deg,#5BB98C,#34d399)">M</div>
        <div class="auth-social-av" style="background:linear-gradient(135deg,#f59e0b,#ea580c)">S</div>
        <div class="auth-social-av" style="background:linear-gradient(135deg,#7A8FBF,#4F7CAC)">A</div>
      </div>
      <div style="flex:1">
        <div class="auth-social-stars">★★★★★</div>
        <div class="auth-social-text">Rejoint par <strong>1 500+ candidats</strong> · <strong>8 000+ CV générés</strong><br>Noté <strong>4,8/5</strong> par nos utilisateurs</div>
      </div>
    </div>

    <!-- Feature pill -->
    <div class="auth-feature" id="auth-feature">
      <div class="auth-feature-icon">💡</div>
      <div class="auth-feature-text"><strong>Passe les filtres,</strong> décroche plus d'entretiens.<br>Pensé pour battre les algorithmes de recrutement.</div>
      <div class="auth-feature-badge">📈</div>
    </div>
  </div>

  <!-- ══ RIGHT — Form panel ══ -->
  <div class="auth-right">
    <div class="auth-box">
      <div class="auth-logo">
        <div class="auth-logo-icon">
          <svg viewBox="0 0 34 34" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
            <path d="M5 12Q5 9 8 9H26Q29 9 29 12V22Q29 25 26 25H19.5L17 29L14.5 25H8Q5 25 5 22Z" fill="rgba(255,255,255,.95)"/>
            <path d="M13 9V8Q13 7 14.5 7H19.5Q21 7 21 8V9" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round"/>
            <circle cx="17" cy="17" r="5.5" fill="#5BB98C"/>
            <circle cx="17" cy="17" r="3.2" fill="rgba(255,255,255,.95)"/>
            <circle cx="17" cy="17" r="1.3" fill="#5BB98C"/>
          </svg>
        </div>
        <h2>JobFinder</h2>
      </div>
      <p class="auth-tagline">Le copilote de ta recherche d'emploi ✦</p>
      <div class="auth-tabs">
        <div class="auth-tab active" id="tab-login" onclick="switchAuthTab('login')">Connexion</div>
        <div class="auth-tab" id="tab-register" onclick="switchAuthTab('register')">Inscription</div>
      </div>
      <div id="auth-login-form">
        <div class="fg"><label>Email</label><input type="email" id="a-email" placeholder="vous@email.com" onkeydown="if(event.key==='Enter')doLogin()"></div>
        <div class="fg"><label>Mot de passe</label><input type="password" id="a-pwd" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
        <div class="auth-error" id="login-err"></div>
        <button class="btn btn-primary" style="width:100%;margin-top:16px;padding:13px;font-size:14px" onclick="doLogin()">→ Se connecter</button>
      </div>
      <div id="auth-register-form" style="display:none">
        <div class="fg"><label>Prénom</label><input type="text" id="r-name" placeholder="Votre prénom"></div>
        <div class="fg"><label>Email</label><input type="email" id="r-email" placeholder="vous@email.com"></div>
        <div class="fg"><label>Mot de passe</label><input type="password" id="r-pwd" placeholder="Min 6 caractères" onkeydown="if(event.key==='Enter')doRegister()"></div>
        <div class="auth-error" id="register-err"></div>
        <button class="btn btn-primary" style="width:100%;margin-top:16px;padding:13px;font-size:14px" onclick="doRegister()">✨ Créer mon compte gratuit</button>
      </div>
      <div class="auth-trust">
        <span class="auth-trust-item"><span>🔒</span> Sécurisé</span>
        <span class="auth-trust-item"><span>⚡</span> Instantané</span>
        <span class="auth-trust-item"><span>🎁</span> Gratuit</span>
      </div>
    </div>
  </div>

</div>

<!-- Toast -->
<div id="toasts"></div>

<!-- Modal -->
<div id="modal-bg" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-hd">
      <h3 id="modal-title">Candidature</h3>
      <button class="modal-x" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body-scroll">
      <div id="modal-body" style="padding-top:20px"></div>
    </div>
    <div class="modal-ft" id="modal-ft"></div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────────
let apps = [], config = {}, selAppId = null, generateCV_force = false;
let generatedCV = '', generatedCVFilename = '', cvContent = '';
let dragId = null;
let currentUser = null;
let allStages = [];

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH — Animations
// ═══════════════════════════════════════════════════════════════════════════════

/* ── Odometer / slot-roll counter ── */
function buildOdo(el, target, suffix){
  const digits = String(target).split('');
  el.innerHTML = digits.map(d=>{
    // Build a column of 0→d digits + suffix in last col
    const nums = [];
    for(let i=0;i<=parseInt(d);i++) nums.push(`<span>${i}</span>`);
    return `<span class="odo-digit" data-final="${d}"><span>0</span>${nums.slice(1).map(s=>s).join('')}</span>`;
  }).join('') + (suffix?`<span style="font-size:13px;font-weight:700;color:rgba(255,255,255,.7);margin-left:1px;line-height:22px">${suffix}</span>`:'');
}

function animateOdo(el){
  el.querySelectorAll('.odo-digit').forEach((col,i)=>{
    const final = parseInt(col.dataset.final);
    const total = col.children.length; // spans
    // total spans = final+1, index 0=first digit(0), index final=final digit
    const targetIdx = final; // we want to show the span at index=final
    const delay = i * 80;
    setTimeout(()=>{
      // translate so the final digit is visible (each span = 22px)
      col.style.transform = `translateY(-${targetIdx * 22}px)`;
    }, delay);
  });
}

function initAuthAnimations(){
  // Stagger stat cards
  const stats = document.querySelectorAll('.auth-stat');
  stats.forEach((s,i)=>{
    const delay = parseInt(s.dataset.delay)||0;
    setTimeout(()=>{
      s.classList.add('visible');
      s.style.transition=`opacity .45s ease, transform .45s cubic-bezier(.22,.61,.36,1)`;
      // Build + animate odometers inside this stat
      const odo = s.querySelector('.odo-wrap');
      if(odo){
        const target = parseInt(odo.dataset.target);
        const suffix = odo.dataset.suffix||'';
        buildOdo(odo, target, suffix);
        // Small extra delay so the card appears first, then digits roll
        setTimeout(()=>animateOdo(odo), 200);
      }
    }, 400 + delay);
  });
  // Social proof + feature
  setTimeout(()=>document.getElementById('auth-social')?.classList.add('visible'), 900);
  setTimeout(()=>document.getElementById('auth-feature')?.classList.add('visible'), 1100);
}

/* Auto-run when overlay is visible */
(function(){
  // Run on DOMContentLoaded if overlay is showing
  window.addEventListener('DOMContentLoaded', ()=>{
    const ov = document.getElementById('auth-overlay');
    if(ov && ov.style.display !== 'none') initAuthAnimations();
  });
  // Also expose so we can call after login check
  window._initAuthAnim = initAuthAnimations;
})();

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════════════════════════════
function switchAuthTab(tab){
  document.getElementById('tab-login').classList.toggle('active', tab==='login');
  document.getElementById('tab-register').classList.toggle('active', tab==='register');
  document.getElementById('auth-login-form').style.display = tab==='login'?'':'none';
  document.getElementById('auth-register-form').style.display = tab==='register'?'':'none';
}

async function doLogin(){
  const email=document.getElementById('a-email').value.trim();
  const pwd=document.getElementById('a-pwd').value;
  const err=document.getElementById('login-err');
  err.style.display='none';
  const data=await post('/api/auth/login',{email,password:pwd});
  if(data.error){err.textContent=data.error;err.style.display='';return;}
  onLogin(data.user);
}

async function doRegister(){
  const name=document.getElementById('r-name').value.trim();
  const email=document.getElementById('r-email').value.trim();
  const pwd=document.getElementById('r-pwd').value;
  const err=document.getElementById('register-err');
  err.style.display='none';
  const data=await post('/api/auth/register',{name,email,password:pwd});
  if(data.error){err.textContent=data.error;err.style.display='';return;}
  onLogin(data.user);
}

function onLogin(user){
  currentUser=user;
  document.getElementById('auth-overlay').style.display='none';
  document.getElementById('user-name').textContent=user.name||user.email;
  document.getElementById('user-avatar').textContent=(user.name||user.email)[0].toUpperCase();
  document.getElementById('user-role-badge').textContent=user.role;
  // Admin nav
  document.getElementById('nav-admin').style.display=user.role==='admin'?'':'none';
  // Couleur badge
  const rb=document.getElementById('user-role-badge');
  rb.style.color=user.role==='admin'?'var(--red)':user.role==='pro'?'var(--purple)':'var(--text3)';
  initApp();
}

async function logout(){
  await post('/api/auth/logout',{});
  currentUser=null;
  // Reset stat animations so they replay
  document.querySelectorAll('.auth-stat').forEach(s=>s.classList.remove('visible'));
  document.getElementById('auth-social')?.classList.remove('visible');
  document.getElementById('auth-feature')?.classList.remove('visible');
  document.getElementById('auth-overlay').style.display='flex';
  document.getElementById('a-pwd').value='';
  setTimeout(()=>window._initAuthAnim&&window._initAuthAnim(), 150);
}

async function checkAuth(){
  const data=await api('/api/auth/me');
  if(data.user){onLogin(data.user);}
  else{
    document.getElementById('auth-overlay').style.display='flex';
    setTimeout(()=>window._initAuthAnim&&window._initAuthAnim(), 100);
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLANNING
// ═══════════════════════════════════════════════════════════════════════════════
const STAGE_TYPES=['Entretien RH','Entretien technique','Entretien téléphonique','Test technique','Assessment','Offre reçue','Autre'];
const STAGE_COLORS={'Entretien RH':'st-rh','Entretien technique':'st-tech','Entretien téléphonique':'st-phone','Test technique':'st-test','Assessment':'st-test','Offre reçue':'st-offer','Autre':'st-other'};
const RESULT_COLORS={'En attente':'r-wait','Positif':'r-ok','Négatif':'r-ko','Annulé':'r-cancel'};

async function loadStages(){
  const data=await api('/api/interview-stages');
  allStages=Array.isArray(data)?data:[];
}

// ── Planning Calendrier ────────────────────────────────────────────────────────
let activePlanFilter='all', calView='7', calOffset=0;

function setPlanFilter(btn){
  document.querySelectorAll('.plan-pill').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  activePlanFilter=btn.dataset.plan;
  renderPlanning();
}
function setCalView(v){
  calView=v; calOffset=0;
  document.querySelectorAll('.cal-view-btn').forEach(b=>b.classList.toggle('active',b.dataset.v===v));
  renderPlanning();
}
function navCal(dir){
  calOffset = dir===0 ? 0 : calOffset+dir;
  renderPlanning();
}

function _planStageColor(s){
  const t=s.stage_type||'';
  if(t.includes('Candidature'))  return '#2F5DA8';
  if(t.includes('RH'))           return '#3b82f6';
  if(t.includes('technique'))    return '#4F7CAC';
  if(t.includes('téléphonique')) return '#10b981';
  if(t.includes('Test')||t.includes('Assessment')) return '#f59e0b';
  if(t.includes('Offre'))        return '#34d399';
  return '#94a3b8';
}
function _stagesForDay(stages, dateStr){
  return stages.filter(s=>(s.scheduled_date||'').slice(0,10)===dateStr);
}
function _todayStr(){ return new Date().toISOString().slice(0,10); }

function renderPlanning(){
  const search=(document.getElementById('plan-search')||{value:''}).value.toLowerCase();
  const ts=new Date(); ts.setHours(0,0,0,0);
  const todayISO=_todayStr();

  let stages=[...allStages].filter(s=>{
    if(activePlanFilter==='sent'      && s.app_status!=='Envoyée') return false;
    if(activePlanFilter==='wait'      && s.result!=='En attente') return false;
    if(activePlanFilter==='interview' && !(s.stage_type||'').includes('Entretien')) return false;
    if(search && !(s.company||'').toLowerCase().includes(search) && !(s.role_name||'').toLowerCase().includes(search)) return false;
    return true;
  });

  if(!allStages.length){
    document.getElementById('cal-grid').innerHTML=`<div class="planning-empty">
      <div style="font-size:40px;margin-bottom:12px">📅</div>
      <div style="font-size:15px;font-weight:700;color:var(--text2);margin-bottom:6px">Aucun entretien planifié</div>
      <div style="font-size:13px;color:var(--text3);max-width:280px;margin:0 auto;line-height:1.6">Passez vos candidatures au statut <strong>Entretien</strong> puis ajoutez une date pour les voir apparaître ici.</div>
      <button class="btn btn-primary btn-sm" style="margin-top:14px" onclick="openAddStageModal()">📅 Planifier un entretien</button>
    </div>`;
    return;
  }
  calView==='7' ? _renderCal7(stages,todayISO) : _renderCal30(stages,todayISO);
}

function _renderCal7(stages, todayISO){
  // Semaine courante (lundi) + offset semaines
  const ref=new Date();
  const dow=ref.getDay()||7; // lun=1..dim=7
  ref.setDate(ref.getDate()-dow+1+calOffset*7);
  const days=[];
  for(let i=0;i<7;i++){const d=new Date(ref);d.setDate(ref.getDate()+i);days.push(d);}

  const s0=days[0].toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
  const s1=days[6].toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'});
  document.getElementById('cal-title').textContent=`${s0} — ${s1}`;

  const NAMES=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
  let html='<div class="cal-7">';
  days.forEach((d,i)=>{
    const dStr=d.toISOString().slice(0,10);
    const isToday=dStr===todayISO;
    const evs=_stagesForDay(stages,dStr);
    html+=`<div class="cal-day-col${isToday?' cal-today':''}">
      <div class="cal-day-hdr">
        <div class="cal-day-name">${NAMES[i]}</div>
        <div class="cal-day-num">${d.getDate()}</div>
      </div>
      <div class="cal-day-events">`;
    if(!evs.length) html+=`<div style="font-size:10px;color:var(--text3);text-align:center;padding:8px 0">—</div>`;
    evs.forEach(s=>{
      const c=_planStageColor(s);
      const time=(s.scheduled_date||'').length>10?s.scheduled_date.slice(11,16):'';
      html+=`<div class="cal-ev" style="background:${c}18;border-left-color:${c};border-left-width:3px" onclick="openModal('${s.application_id}')">
        ${time?`<div class="cal-ev-time" style="color:${c};font-weight:800">${time}</div>`:''}
        <div class="cal-ev-co">${s.company||'?'}</div>
        <div class="cal-ev-type" style="color:${c};opacity:.85">${s.stage_type||'Entretien'}</div>
      </div>`;
    });
    html+=`</div></div>`;
  });
  html+='</div>';
  document.getElementById('cal-grid').innerHTML=html;
}

function _renderCal30(stages, todayISO){
  const ref=new Date();
  const year=ref.getFullYear(), month=ref.getMonth()+calOffset;
  const d1=new Date(year, month, 1);
  const daysInMonth=new Date(year, month+1, 0).getDate();

  document.getElementById('cal-title').textContent=
    d1.toLocaleDateString('fr-FR',{month:'long',year:'numeric'});

  // Décalage semaine (lundi = 0)
  let firstDow=d1.getDay(); firstDow=firstDow===0?6:firstDow-1;

  const NAMES=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
  let html='<div class="cal-30">';
  NAMES.forEach(n=>{ html+=`<div class="cal-30-hdr">${n}</div>`; });
  for(let i=0;i<firstDow;i++) html+=`<div class="cal-30-cell other-month"></div>`;

  for(let day=1;day<=daysInMonth;day++){
    const d=new Date(year, month, day);
    const dStr=d.toISOString().slice(0,10);
    const isToday=dStr===todayISO;
    const evs=_stagesForDay(stages,dStr);
    html+=`<div class="cal-30-cell${isToday?' cal-today':''}">
      <div class="cal-30-num">${day}</div>`;
    evs.slice(0,3).forEach(s=>{
      const c=_planStageColor(s);
      html+=`<div class="cal-30-ev" style="background:${c}18;border-left-color:${c};color:var(--text);border-left-width:3px" onclick="openModal('${s.application_id}')">${s.company||'?'}</div>`;
    });
    if(evs.length>3) html+=`<div class="cal-30-more">+${evs.length-3} autres</div>`;
    html+=`</div>`;
  }
  html+='</div>';
  document.getElementById('cal-grid').innerHTML=html;
}

async function openAddStageModal(){
  // Ouvre modal candidature en mode ajout stage
  const appList=apps.map(a=>`<option value="${a.id}">${a.company} — ${a.role||''}</option>`).join('');
  if(!appList){toast('Ajoutez d\'abord une candidature','error');return;}
  const html=`
    <div class="fg"><label>Candidature</label><select id="asm-app">${appList}</select></div>
    <div class="fg"><label>Type</label><select id="asm-type">${STAGE_TYPES.map(t=>`<option>${t}</option>`).join('')}</select></div>
    <div class="flex gap-2">
      <div class="fg" style="flex:1"><label>Date</label><input type="date" id="asm-date" value="${new Date().toISOString().slice(0,10)}"></div>
      <div class="fg" style="flex:1"><label>Heure</label><input type="time" id="asm-time" value="10:00"></div>
    </div>
    <div class="fg"><label>Notes</label><input id="asm-notes" placeholder="Lieu, contact, préparation..."></div>
  `;
  document.getElementById('modal-title').textContent='📅 Planifier un entretien';
  document.getElementById('modal-body').innerHTML=html;
  document.getElementById('modal-ft').innerHTML=`<button class="btn btn-primary" onclick="saveNewStage()">Enregistrer</button>`;
  document.getElementById('modal-bg').style.display='flex';
}

async function saveNewStage(){
  const app_id=document.getElementById('asm-app').value;
  const stage_type=document.getElementById('asm-type').value;
  const date=document.getElementById('asm-date').value;
  const time=document.getElementById('asm-time').value;
  const notes=document.getElementById('asm-notes').value;
  const scheduled_date=date+(time?'T'+time:'');
  const data=await post('/api/interview-stages',{application_id:app_id,stage_type,scheduled_date,notes,result:'En attente'});
  if(data.error){toast(data.error,'error');return;}
  allStages.push(data);
  closeModal();
  renderPlanning();
  toast('Entretien planifié !','success');
}

async function deleteStage(id){
  if(!confirm('Supprimer cet entretien ?')) return;
  await fetch('/api/interview-stages/'+id,{method:'DELETE'});
  allStages=allStages.filter(s=>s.id!==id);
  renderPlanning();
  toast('Supprimé','info');
}

async function updateStageResult(id, result){
  const data=await fetch('/api/interview-stages/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({result})});
  const d=await data.json();
  const idx=allStages.findIndex(s=>s.id===id);
  if(idx>=0) allStages[idx]=d;
  renderPlanning();
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADMIN
// ═══════════════════════════════════════════════════════════════════════════════
async function loadAdminUsers(){
  const data=await api('/api/admin/users');
  if(data.error){toast(data.error,'error');return;}
  const tbody=document.getElementById('admin-users-tbody');
  tbody.innerHTML=data.map(u=>`
    <tr style="border-top:1px solid var(--border)">
      <td><strong>${u.name||'—'}</strong></td>
      <td style="color:var(--text2)">${u.email}</td>
      <td style="color:var(--text3);font-size:12px">${u.created_at?.slice(0,10)||''}</td>
      <td>
        <select class="role-select" onchange="changeRole(${u.id},this.value)">
          <option ${u.role==='membre'?'selected':''}>membre</option>
          <option ${u.role==='pro'?'selected':''}>pro</option>
          <option ${u.role==='admin'?'selected':''}>admin</option>
        </select>
      </td>
      <td>
        ${u.id!==currentUser?.id?`<button class="btn btn-red btn-sm" onclick="deleteUser(${u.id})">Supprimer</button>`:'<span style="color:var(--text3);font-size:12px">Vous</span>'}
      </td>
    </tr>`).join('');
}

async function changeRole(uid, role){
  const data=await fetch('/api/admin/users/'+uid,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({role})});
  const d=await data.json();
  if(d.error){toast(d.error,'error');return;}
  toast(`Rôle mis à jour → ${role}`,'success');
}

async function deleteUser(uid){
  if(!confirm('Supprimer définitivement cet utilisateur et toutes ses données ?')) return;
  const data=await fetch('/api/admin/users/'+uid,{method:'DELETE'});
  const d=await data.json();
  if(d.error){toast(d.error,'error');return;}
  toast('Utilisateur supprimé','info');
  loadAdminUsers();
}
let photoB64 = '', photoMime = 'image/jpeg';  // profile photo
let docsLoaded = false;  // flag docs chargés depuis serveur

const STATUSES = ['Envoyée','En attente','Entretien','Acceptée','Refusée'];
const S_ICON = {'Envoyée':'📤','En attente':'⏳','Entretien':'🎤','Acceptée':'✅','Refusée':'❌'};
const S_KEY  = s => s.replace(/ /g,'-');

// ── Boot ───────────────────────────────────────────────────────────────────────
(async()=>{
  // Nav clicks (avant checkAuth pour que les boutons soient prêts)
  document.querySelectorAll('.nav-item').forEach(el=>{
    el.addEventListener('click',()=>nav(el.dataset.page));
  });
  // Vérifie la session existante
  await checkAuth();
})();

// Appelé après login réussi
async function initApp(){
  await loadConfig();
  await loadApps();
  await loadPhotoState();
  await loadDocsState();
  await loadStages();
  render();
}

// ── Navigation ─────────────────────────────────────────────────────────────────
function nav(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.bn-btn[data-page]').forEach(n=>n.classList.remove('active'));
  const pg=document.getElementById('page-'+id);
  const nv=document.querySelector(`[data-page="${id}"]`);
  if(pg) pg.classList.add('active');
  // Sync sidebar + bottom nav
  document.querySelectorAll(`[data-page="${id}"]`).forEach(el=>el.classList.add('active'));
  if(id==='applications') renderKanban();
  if(id==='interviews')   renderAL();
  if(id==='dashboard')    renderDash();
  if(id==='settings')     loadSettings();
  if(id==='planning'){loadStages().then(renderPlanning);}
  if(id==='templates')    loadTemplates();
  if(id==='admin')        loadAdminUsers();
  // Close sidebar on mobile when navigating
  if(window.innerWidth<=768) closeSidebar();
}

// ── Toast ──────────────────────────────────────────────────────────────────────
function toast(msg, type='info'){
  const el=document.createElement('div');
  el.className=`toast ${type}`;
  const ico={success:'✅',error:'❌',info:'ℹ️'};
  el.innerHTML=`<span>${ico[type]||'ℹ️'}</span>${msg}`;
  document.getElementById('toasts').appendChild(el);
  setTimeout(()=>{el.style.animation='toastIn .25s ease reverse';setTimeout(()=>el.remove(),250);},3400);
}

// ── API helpers ────────────────────────────────────────────────────────────────
async function api(url, opts={}){
  const r = await fetch(url,{headers:{'Content-Type':'application/json'},...opts});
  if(r.status===401){
    // Session expirée → retour au login
    currentUser=null;
    document.getElementById('auth-overlay').style.display='flex';
    setTimeout(()=>window._initAuthAnim&&window._initAuthAnim(), 100);
    return {error:'Session expirée, reconnectez-vous'};
  }
  return r.json();
}
const post = (url,data)=>api(url,{method:'POST',body:JSON.stringify(data)});
const put  = (url,data)=>api(url,{method:'PUT', body:JSON.stringify(data)});
const del  = (url)     =>api(url,{method:'DELETE'});

// ── Config ─────────────────────────────────────────────────────────────────────
async function loadConfig(){
  config = await api('/api/config');

  // Preload CV if available
  const cv = await api('/api/cv-base');
  if(cv.html){ cvContent=cv.html; document.getElementById('a-cv-name').value=cv.name||'cv_base.html'; }
}

// ── Apps ───────────────────────────────────────────────────────────────────────
async function loadApps(){ apps = await api('/api/applications'); }

function render(){ renderDash(); updateBadges(); populateAppSelect(); }

function populateAppSelect(){
  const sel=document.getElementById('a-from-app');
  if(!sel) return;
  const cur=sel.value;
  sel.innerHTML='<option value="">— Choisir une candidature existante —</option>';
  [...apps].reverse().forEach(a=>{
    const opt=document.createElement('option');
    opt.value=a.id;
    opt.textContent=`${a.company||'?'} — ${a.role||'?'}${a.status?' ('+a.status+')':''}`;
    sel.appendChild(opt);
  });
  if(cur) sel.value=cur;
}

function importFromApp(id){
  if(!id) return;
  const a=apps.find(x=>x.id==id);
  if(!a) return;
  if(a.company) document.getElementById('a-co').value=a.company;
  if(a.role)    document.getElementById('a-role').value=a.role;
  if(a.job_url) document.getElementById('a-url').value=a.job_url;
  if(a.job_desc){ document.getElementById('a-desc').value=a.job_desc; }
  toast(`Candidature "${a.company}" importée`,'success');
}

function updateBadges(){
  document.getElementById('badge-apps').textContent=apps.length;
  // Bottom nav badge
  const bnBadge=document.getElementById('bn-badge-apps');
  if(bnBadge){bnBadge.textContent=apps.length;bnBadge.classList.toggle('show',apps.length>0);}
  const n=apps.filter(a=>a.status==='Entretien').length;
  const b=document.getElementById('badge-int');
  b.textContent=n; b.classList.toggle('hidden',!n);
}

// ── Dashboard ──────────────────────────────────────────────────────────────────
function renderDash(){
  document.getElementById('st-total').textContent=apps.length;
  document.getElementById('st-int').textContent  =apps.filter(a=>a.status==='Entretien').length;
  document.getElementById('st-pend').textContent =apps.filter(a=>a.status==='En attente').length;
  document.getElementById('st-acc').textContent  =apps.filter(a=>a.status==='Acceptée').length;

  // Bannière profil
  const hasSummary=config&&config.has_summary;
  const hasDocs=config&&config.has_docs;
  const banner=document.getElementById('profile-banner');
  const bannerMsg=document.getElementById('profile-banner-msg');
  if(banner && bannerMsg){
    if(!hasSummary&&!hasDocs){
      bannerMsg.textContent='Ajoutez votre résumé personnel et importez vos documents pour des CV vraiment personnalisés.';
      banner.style.display='flex';
    } else if(!hasSummary){
      bannerMsg.textContent='Ajoutez votre résumé personnel dans Paramètres pour enrichir la génération de CV.';
      banner.style.display='flex';
    } else if(!hasDocs){
      bannerMsg.textContent='Importez vos anciens CV ou documents LinkedIn pour de meilleurs résultats.';
      banner.style.display='flex';
    } else {
      banner.style.display='none';
    }
  }

  const recent=[...apps].reverse().slice(0,10);
  const emptyHtml=`<div class="empty" style="padding:30px 20px 20px">
    <div class="empty-i">📭</div>
    <h4>Aucune candidature pour l'instant</h4>
    <p>Commencez par ajouter une candidature ou adaptez votre CV à une offre.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-top:18px;text-align:left;max-width:520px">
      <div style="padding:14px;background:var(--card2);border:1px solid var(--border);border-radius:12px;cursor:pointer" onclick="openModal(null)">
        <div style="font-size:20px;margin-bottom:6px">➕</div>
        <div style="font-size:12px;font-weight:700;color:var(--text);margin-bottom:3px">Ajouter une candidature</div>
        <div style="font-size:11px;color:var(--text3);line-height:1.5">Enregistrez une offre à laquelle vous avez postulé</div>
      </div>
      <div style="padding:14px;background:var(--card2);border:1px solid var(--border);border-radius:12px;cursor:pointer" onclick="nav('adapter')">
        <div style="font-size:20px;margin-bottom:6px">✨</div>
        <div style="font-size:12px;font-weight:700;color:var(--text);margin-bottom:3px">Adapter mon CV</div>
        <div style="font-size:11px;color:var(--text3);line-height:1.5">Générez un CV personnalisé et enregistrez la candidature</div>
      </div>
      <div style="padding:14px;background:var(--card2);border:1px solid var(--border);border-radius:12px;cursor:pointer" onclick="nav('settings')">
        <div style="font-size:20px;margin-bottom:6px">⚙️</div>
        <div style="font-size:12px;font-weight:700;color:var(--text);margin-bottom:3px">Compléter mon profil</div>
        <div style="font-size:11px;color:var(--text3);line-height:1.5">Ajoutez votre résumé et documents pour de meilleurs CV</div>
      </div>
    </div>
  </div>`;

  // Table (desktop)
  const tbody=document.getElementById('dash-tbody');
  if(!recent.length){ tbody.innerHTML=`<tr><td colspan="6">${emptyHtml}</td></tr>`; }
  else { tbody.innerHTML=recent.map(a=>`
    <tr onclick="openModal('${a.id}')">
      <td class="tx-m tx-sm">${a.date||''}</td>
      <td><strong>${a.company||''}</strong></td>
      <td class="tx-m">${a.role||''}</td>
      <td><span class="sbadge s-${S_KEY(a.status)}">${S_ICON[a.status]||''} ${a.status}</span></td>
      <td class="tx-sm" style="color:var(--blue)">${a.interview_date?'📅 '+a.interview_date:''}</td>
      <td><button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();openModal('${a.id}')">✏️</button></td>
    </tr>`).join(''); }

  // Cards (mobile)
  const cards=document.getElementById('dash-cards');
  if(cards){
    if(!recent.length){ cards.innerHTML=emptyHtml; }
    else { cards.innerHTML=recent.map(a=>`
      <div class="m-app-card" onclick="openModal('${a.id}')">
        <div class="m-app-card-body">
          <div class="m-app-card-co">${a.company||''}</div>
          <div class="m-app-card-role">${a.role||''}</div>
          <div class="m-app-card-foot">
            <span class="sbadge s-${S_KEY(a.status)}" style="font-size:10px;padding:2px 7px">${S_ICON[a.status]||''} ${a.status}</span>
            <span class="m-app-card-date">${a.date||''}</span>
            ${a.interview_date?`<span style="font-size:11px;color:var(--blue)">🎤 ${a.interview_date}</span>`:''}
          </div>
        </div>
        <div class="m-app-card-arrow">›</div>
      </div>`).join(''); }
  }
}

// ── CV Adapter ─────────────────────────────────────────────────────────────────
function loadCVFile(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    cvContent=ev.target.result;
    document.getElementById('a-cv-name').value=file.name;
    post('/api/cv-base',{html:cvContent,name:file.name});
    toast('CV importé : '+file.name,'success');
  };
  reader.readAsText(file);
}

// ── Documentation (Settings) ───────────────────────────────────────────────────
async function loadDocsState(){
  const d=await api('/api/docs');
  docsLoaded=!!(d.text&&d.text.length>10)||(d.summary&&d.summary.length>10);
}

async function loadSettingsDocs(ev){
  const files=[...ev.target.files]; if(!files.length) return;
  const st=document.getElementById('s-doc-status');
  st.style.color='var(--yellow)'; st.textContent=`Extraction de ${files.length} fichier(s)...`;
  let allText=''; const names=[];
  // Charger docs existants
  const existing=await api('/api/docs');
  if(existing.text) allText=existing.text;
  const existingNames=existing.names||[];
  for(const file of files){
    const b64=await fileToB64(file);
    const res=await post('/api/extract-doc',{b64,mime:file.type,name:file.name});
    allText+=`\n\n--- ${file.name} ---\n`+(res.text||'');
    names.push(file.name);
  }
  const allNames=[...existingNames,...names];
  await post('/api/docs',{text:allText,names:allNames});
  document.getElementById('s-doc-names').value=allNames.join(', ');
  st.style.color='var(--green)'; st.textContent=`✅ ${allNames.length} document(s) sauvegardé(s) — ${allText.length} caractères`;
  docsLoaded=true;
  toast(`${names.length} document(s) ajouté(s) !`,'success');
  ev.target.value='';
}

async function clearSettingsDocs(){
  if(!confirm('Supprimer toute la documentation ?')) return;
  await post('/api/docs',{text:'',names:[]});
  document.getElementById('s-doc-names').value='';
  document.getElementById('s-doc-status').textContent='';
  docsLoaded=false;
  toast('Documentation effacée','info');
}

// ── Télécharger CV en PDF ──────────────────────────────────────────────────────
async function downloadPDF(){
  if(!generatedCVFilename){toast('Générez d\'abord un CV','error');return;}
  const co=document.getElementById('a-co').value.trim()||'CV';
  const ro=document.getElementById('a-role').value.trim()||'poste';
  const dlName=(co+'_'+ro+'.pdf').replace(/[^a-zA-Z0-9._-]/g,'_');

  const btn=document.getElementById('pdfbtn');
  btn.disabled=true; btn.textContent='⏳ PDF en cours...';
  toast('⏳ Génération du PDF...','info');

  try{
    const resp=await fetch('/api/download-pdf',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({filename:generatedCVFilename})
    });
    if(!resp.ok){
      const err=await resp.json().catch(()=>({error:'Erreur serveur'}));
      throw new Error(err.error||'Erreur serveur');
    }
    const blob=await resp.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url; a.download=dlName; a.click();
    setTimeout(()=>URL.revokeObjectURL(url),5000);
    toast('✅ PDF téléchargé !','success');
  }catch(e){
    toast('Erreur : '+e.message,'error');
  }finally{
    btn.disabled=false; btn.textContent='⬇️ Télécharger PDF';
  }
}

// ── Fetch URL ──────────────────────────────────────────────────────────────────
async function fetchURL(){
  const url=document.getElementById('a-url').value.trim();
  if(!url){toast('Entrez une URL d\'annonce','error');return;}
  const btn=document.getElementById('fetchbtn');
  const st=document.getElementById('fetch-status');
  btn.disabled=true; btn.textContent='⏳'; st.textContent='Récupération en cours...';
  const data=await post('/api/fetch-url',{url});
  btn.disabled=false; btn.textContent='⬇️ Récupérer';
  if(data.error){st.textContent='❌ '+data.error; toast('Erreur fetch URL','error');return;}
  // Toujours remplir les champs même si la valeur est vide
  document.getElementById('a-role').value=data.title||'';
  document.getElementById('a-co').value=data.company||'';
  document.getElementById('a-desc').value=data.description||'';
  const filled=[data.title,data.company,data.description].filter(Boolean).length;
  if(filled===0){
    st.textContent='⚠️ Aucune info extraite — vérifiez l\'URL ou collez la description manuellement';
    toast('Aucune info extraite','error');
  } else {
    st.textContent=`✅ ${filled}/3 champ(s) rempli(s)`;
    toast('Offre récupérée !','success');
  }
}

// ── Template toggle ────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  const chk=document.getElementById('use-template');
  const row=document.getElementById('cv-base-row');
  const note=document.getElementById('template-note');
  if(chk) chk.addEventListener('change',()=>{
    row.style.display=chk.checked?'none':'';
    note.textContent=chk.checked
      ?'Le template cv_vibe_modern sera rempli par l\'IA avec vos infos adaptées au poste.'
      :'Votre CV de base HTML sera adapté par l\'IA selon l\'offre.';
  });
});

async function generateCV(){
  const co=document.getElementById('a-co').value.trim();
  const ro=document.getElementById('a-role').value.trim();
  const desc=document.getElementById('a-desc').value.trim();
  const useTemplate=document.getElementById('use-template').checked;
  if(desc.length<30){toast('Collez la description complète du poste ou récupérez via l\'URL','error');return;}

  // Avertissement docs manquants
  const remind=document.getElementById('doc-reminder');
  const hasSummary=config&&config.has_summary;
  const hasAnyDocs=docsLoaded||(config&&config.has_docs);
  if(!hasAnyDocs&&!hasSummary){
    // Blocage avec invitation à compléter le profil
    remind.style.display='';
    remind.innerHTML=`⚠️ Ton profil est vide — sans résumé ni documents, le CV sera générique.<br>
      <strong>👉 <a href="#" onclick="nav('settings');return false" style="color:var(--accent)">Aller dans Paramètres → Résumé &amp; Documentation</a></strong>
      pour un résultat vraiment personnalisé. <a href="#" onclick="document.getElementById('doc-reminder').style.display='none';generateCV_force=true;generateCV()" style="color:var(--text3);font-size:11px;margin-left:6px">Générer quand même →</a>`;
    if(!generateCV_force){remind.scrollIntoView({behavior:'smooth',block:'nearest'});return;}
    generateCV_force=false;
  } else {
    remind.style.display='none';
  }

  const overlay=document.getElementById('gen-overlay');
  const btn=document.getElementById('genbtn');
  const genPhotoInner=document.getElementById('gen-photo-inner');
  const genLabel=document.getElementById('gen-label');

  // Inject profile photo if available
  if(photoB64){
    genPhotoInner.innerHTML=`<img src="data:${photoMime};base64,${photoB64}" alt="photo">`;
  } else {
    genPhotoInner.innerHTML='🤖';
  }

  // Cycling messages
  const cycleMessages=[
    'Analyse de l\'offre...',
    'Identification des compétences clés...',
    'Adaptation du CV au poste...',
    'Mise en valeur des expériences...',
    'Amélioration de la rédaction...',
    'Optimisation des mots-clés...',
    'Personnalisation du profil...',
    'Finalisation du document...',
  ];
  let msgIdx=0;
  genLabel.textContent=cycleMessages[0];
  const msgTimer=setInterval(()=>{
    msgIdx=(msgIdx+1)%cycleMessages.length;
    genLabel.style.opacity='0';
    setTimeout(()=>{genLabel.textContent=cycleMessages[msgIdx];genLabel.style.opacity='1';},200);
  },1800);
  genLabel.style.transition='opacity .2s ease';

  overlay.classList.add('show'); btn.disabled=true; btn.textContent='⏳ Génération...';
  document.getElementById('gen-status').textContent='';
  document.getElementById('savebtn').style.display='none';

  let data;
  if(useTemplate){
    // Les docs sont lus côté serveur depuis data/docs.json
    data=await post('/api/adapt-cv-template',{company:co,role:ro,job_desc:desc});
  } else {
    data=await post('/api/adapt-cv',{company:co,role:ro,job_desc:desc,cv_html:cvContent});
  }
  clearInterval(msgTimer);
  overlay.classList.remove('show'); btn.disabled=false; btn.textContent='✨ Générer mon CV';

  if(data.error){toast(data.error,'error');document.getElementById('gen-status').textContent='❌ '+data.error;return;}
  generatedCV=data.html;
  generatedCVFilename=data.filename||'';
  document.getElementById('cv-preview').srcdoc=generatedCV;
  document.getElementById('gen-status').textContent=`✅ ${data.filename}`;
  document.getElementById('savebtn').style.display='';
  toast('CV adapté généré !','success');
}

function previewCV(){
  if(!generatedCV){toast('Générez d\'abord un CV','error');return;}
  const w=window.open('','_blank'); w.document.write(generatedCV); w.document.close();
}

async function saveAndApply(){
  if(!generatedCV){toast('Générez d\'abord un CV','error');return;}
  const co=document.getElementById('a-co').value.trim()||'Entreprise';
  const ro=document.getElementById('a-role').value.trim()||'Poste';
  const desc=document.getElementById('a-desc').value.trim();
  const a=await post('/api/applications',{
    company:co, role:ro,
    job_desc:desc.slice(0,1000),
    status:'Envoyée',
    cv_filename:generatedCVFilename
  });
  apps.push(a); updateBadges(); renderKanban(); renderDash();
  await loadStages(); // planning auto-mis à jour
  toast(`Candidature chez ${co} enregistrée avec le CV !`,'success');
}

// ── Kanban ─────────────────────────────────────────────────────────────────────
let mobKanbanStatus = 'Toutes';
function renderKanban(){
  // Desktop kanban
  const k=document.getElementById('kanban');
  k.innerHTML=STATUSES.map(s=>{
    const sk=S_KEY(s);
    const col=apps.filter(a=>a.status===s);
    return `<div class="kcol col-${sk}" ondragover="dOver(event)" ondrop="dDrop(event,'${s}')">
      <div class="kcol-hd">${S_ICON[s]} ${s}<span class="cnt">${col.length}</span></div>
      <div class="kcol-body">
        ${col.map(a=>`
          <div class="kcard" draggable="true" ondragstart="dStart(event,'${a.id}')" onclick="openModal('${a.id}')">
            <h5>${a.company}</h5>
            <div class="kcard-co">${a.role}</div>
            <div class="kcard-date">📅 ${a.date||''}</div>
            ${a.interview_date?`<div class="kcard-int">🎤 ${a.interview_date}</div>`:''}
            ${a.cv_filename?`<div class="kcard-note">📄 CV adapté disponible</div>`:''}
            ${a.notes?`<div class="kcard-note">📝 ${a.notes}</div>`:''}
          </div>`).join('')||`<div class="drop-zone" ondragover="dOver(event)" ondrop="dDrop(event,'${s}')">Déposez ici</div>`}
      </div>
    </div>`;
  }).join('');
  // Mobile kanban
  renderKanbanMobile();
}
function renderKanbanMobile(){
  const tabs=document.getElementById('mob-status-tabs');
  const list=document.getElementById('mob-kanban-list');
  if(!tabs||!list) return;
  const allStatuses=['Toutes',...STATUSES];
  tabs.innerHTML=allStatuses.map(s=>`
    <button class="mob-stab${mobKanbanStatus===s?' active':''}" onclick="setMobKanbanStatus('${s}')">
      ${s==='Toutes'?'Toutes':S_ICON[s]+' '+s}
      <span style="opacity:.65;margin-left:4px">${s==='Toutes'?apps.length:apps.filter(a=>a.status===s).length}</span>
    </button>`).join('');
  const filtered=mobKanbanStatus==='Toutes'?[...apps].reverse():apps.filter(a=>a.status===mobKanbanStatus).reverse();
  if(!filtered.length){
    list.innerHTML=`<div class="empty"><div class="empty-i">📭</div><h4>Aucune candidature</h4></div>`;
    return;
  }
  list.innerHTML=filtered.map(a=>`
    <div class="m-app-card" onclick="openModal('${a.id}')">
      <div class="m-app-card-body">
        <div class="m-app-card-co">${a.company||''}</div>
        <div class="m-app-card-role">${a.role||''}</div>
        <div class="m-app-card-foot">
          <span class="sbadge s-${S_KEY(a.status)}" style="font-size:10px;padding:2px 7px">${S_ICON[a.status]||''} ${a.status}</span>
          <span class="m-app-card-date">${a.date||''}</span>
          ${a.interview_date?`<span style="font-size:11px;color:var(--blue)">🎤 ${a.interview_date}</span>`:''}
        </div>
        ${a.notes?`<div style="font-size:11px;color:var(--text3);margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">📝 ${a.notes}</div>`:''}
      </div>
      <div class="m-app-card-arrow">›</div>
    </div>`).join('');
}
function setMobKanbanStatus(s){ mobKanbanStatus=s; renderKanbanMobile(); }

function dStart(e,id){dragId=id;e.dataTransfer.effectAllowed='move';}
function dOver(e){e.preventDefault();e.currentTarget.classList.add('over');}
async function dDrop(e,status){
  e.preventDefault();
  document.querySelectorAll('.drop-zone,.kcol').forEach(el=>el.classList.remove('over'));
  if(!dragId) return;
  const a=apps.find(x=>x.id===dragId);
  if(!a||a.status===status){dragId=null;return;}
  a.status=status;
  await put(`/api/applications/${a.id}`,{status});
  dragId=null; renderKanban(); renderDash(); updateBadges();
  toast('Statut mis à jour : '+status,'success');
}

// ── Interviews ─────────────────────────────────────────────────────────────────
function renderAL(){
  const al=document.getElementById('al');
  if(!apps.length){al.innerHTML=`<div class="empty"><div class="empty-i">🎤</div><h4>Aucun entretien planifié</h4><p>Vos entretiens apparaîtront ici une fois vos candidatures au statut <strong>Entretien</strong>.</p></div>`;return;}
  al.innerHTML=[...apps].reverse().map(a=>`
    <div class="al-item${selAppId===a.id?' active':''}" onclick="selApp('${a.id}')">
      <h5>${S_ICON[a.status]||'📋'} ${a.company}</h5>
      <p>${a.role}</p>
      ${a.interview_prep?'<div class="prep-ok">📝 Fiche prête</div>':''}
    </div>`).join('');
}

function selApp(id){
  selAppId=id; renderAL();
  const a=apps.find(x=>x.id===id); if(!a) return;
  const panel=document.getElementById('prep-panel');
  panel.innerHTML=`
    <div class="flex items-c justify-b" style="margin-bottom:18px;flex-shrink:0">
      <div>
        <div style="font-size:17px;font-weight:700;color:var(--text)">${a.company} — ${a.role}</div>
        <div class="tx-sm tx-m mt1">Candidature : ${a.date||''}${a.interview_date?' · Entretien : '+a.interview_date:''}</div>
      </div>
      <div class="flex gap-2">
        <button class="btn btn-primary btn-sm" id="prepbtn" onclick="genPrep('${a.id}')">✨ Générer fiche</button>
        <button class="btn btn-secondary btn-sm" onclick="openPrepTab('${a.id}')">🖨️ Ouvrir</button>
        <button class="btn btn-secondary btn-sm" onclick="savePrep('${a.id}')">💾</button>
      </div>
    </div>
    <div id="prep-content" style="flex:1">
      ${a.interview_prep
        ?`<div class="prep-raw">${a.interview_prep}</div>`
        :`<div class="empty" style="margin:auto"><div class="empty-i">📋</div><h4>Aucune fiche générée</h4><p>Cliquez sur "✨ Générer fiche" pour créer votre préparation</p></div>`}
    </div>`;
}

async function genPrep(id){
  const a=apps.find(x=>x.id===id); if(!a) return;
  const btn=document.getElementById('prepbtn');
  btn.textContent='⏳'; btn.disabled=true;
  const cv=await api('/api/cv-base');
  const data=await post('/api/interview-prep',{app_id:id,company:a.company,role:a.role,job_desc:a.job_desc||'',cv_html:cv.html||''});
  btn.textContent='✨ Générer fiche'; btn.disabled=false;
  if(data.error){toast(data.error,'error');return;}
  a.interview_prep=data.prep;
  document.getElementById('prep-content').innerHTML=`<div class="prep-raw">${data.prep}</div>`;
  renderAL(); toast('Fiche générée !','success');
}

function savePrep(id){
  const a=apps.find(x=>x.id===id); if(!a) return;
  put(`/api/applications/${a.id}`,{interview_prep:a.interview_prep||''});
  toast('Notes sauvegardées','success');
}

function openPrepTab(id){
  const a=apps.find(x=>x.id===id);
  if(!a?.interview_prep){toast('Générez d\'abord une fiche','info');return;}
  const w=window.open('','_blank');
  const esc=a.interview_prep.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  w.document.write(`<!DOCTYPE html><html><head><meta charset="utf-8">
    <title>${a.company} — Fiche entretien</title>
    <style>body{font-family:system-ui;max-width:800px;margin:40px auto;background:#F7F9FC;color:#1E3A5F;padding:24px;line-height:1.8}
    h1{color:#2F5DA8;border-bottom:2px solid #E2EAF4;padding-bottom:12px;margin-bottom:24px}
    pre{white-space:pre-wrap;font-family:inherit;font-size:14px;color:#374151}
    @media print{body{background:#fff;color:#000}}</style></head>
    <body><h1>🎤 ${a.company} — ${a.role}</h1><pre>${esc}</pre></body></html>`);
  w.document.close();
}

// ── Settings ───────────────────────────────────────────────────────────────────
async function loadSettings(){
  const cv=await api('/api/cv-base');
  if(cv.name){document.getElementById('s-cv-name').value=cv.name;document.getElementById('s-cv-status').textContent='✅ '+cv.name;}
  // Résumé + Docs
  const d=await api('/api/docs');
  if(d.summary) document.getElementById('s-summary').value=d.summary;
  if(d.names&&d.names.length){
    document.getElementById('s-doc-names').value=d.names.join(', ');
    document.getElementById('s-doc-status').textContent=`✅ ${d.names.length} document(s) — ${(d.text||'').length} caractères`;
  }
  // Photo
  renderPhotoCard();
}

async function saveSummary(){
  const text=document.getElementById('s-summary').value.trim();
  const d=await api('/api/docs');
  await post('/api/docs',{text:d.text||'', names:d.names||[], summary:text});
  const st=document.getElementById('s-summary-status');
  st.textContent='✅ Résumé sauvegardé !';
  docsLoaded=!!(text||(d.text&&d.text.length>10));
  setTimeout(()=>st.textContent='',3000);
  toast('Résumé sauvegardé !','success');
}

async function importCV(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=async ev=>{
    const r=await post('/api/cv-base',{html:ev.target.result,name:file.name});
    document.getElementById('s-cv-name').value=file.name;
    document.getElementById('s-cv-status').textContent='✅ '+file.name;
    cvContent=ev.target.result;
    document.getElementById('a-cv-name').value=file.name;
    toast('CV importé : '+file.name,'success');
  };
  reader.readAsText(file);
}

// ── Utilities ──────────────────────────────────────────────────────────────────
function fileToB64(file){
  return new Promise(res=>{
    const r=new FileReader();
    r.onload=e=>res(e.target.result.split(',')[1]);
    r.readAsDataURL(file);
  });
}
function fileMime(file){ return file.type||'application/octet-stream'; }

// ── Photo profil ───────────────────────────────────────────────────────────────
async function loadPhotoState(){
  const d=await api('/api/photo');
  if(d.b64){ photoB64=d.b64; photoMime=d.mime||'image/jpeg'; }
}

function renderPhotoCard(){
  const wrap=document.getElementById('ph-preview-wrap');
  const img =document.getElementById('ph-preview');
  const nm  =document.getElementById('ph-name');
  const st  =document.getElementById('ph-status');
  const del =document.getElementById('ph-del-btn');
  if(!wrap) return;
  if(photoB64){
    img.src=`data:${photoMime};base64,${photoB64}`;
    wrap.style.display='';
    nm.value='Photo enregistrée ✅';
    st.textContent='✅ Photo active — sera insérée dans le CV';
    if(del) del.style.display='';
  } else {
    wrap.style.display='none';
    nm.value='';
    st.textContent='';
    if(del) del.style.display='none';
  }
}

async function loadPhoto(ev){
  const file=ev.target.files[0]; if(!file) return;
  const b64=await fileToB64(file);
  const mime=file.type||'image/jpeg';
  photoB64=b64; photoMime=mime;
  await post('/api/photo',{b64,mime});
  renderPhotoCard();
  toast('Photo de profil enregistrée !','success');
  ev.target.value='';
}

async function removePhoto(){
  if(!confirm('Supprimer la photo de profil ?')) return;
  photoB64=''; photoMime='image/jpeg';
  await post('/api/photo',{b64:'',mime:'image/jpeg'});
  renderPhotoCard();
  toast('Photo supprimée','info');
}

async function saveSettings(){
  await post('/api/config',{});
  toast('Paramètres sauvegardés !','success');
}

// ── Modal ──────────────────────────────────────────────────────────────────────
function openModal(id){
  selAppId=id||null;
  const a=id?apps.find(x=>String(x.id)===String(id)):null;
  const td=new Date().toISOString().split('T')[0];
  const stagesForApp=allStages.filter(s=>String(s.application_id)===String(id));

  const stagesHTML=a?`
    <hr class="div">
    <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:10px">📅 Étapes d'entretien</div>
    <div class="stages-list" id="modal-stages-list">
      ${stagesForApp.length?stagesForApp.map(s=>`
        <div class="stage-item" data-sid="${s.id}">
          <div>
            <div style="font-size:12px;font-weight:600;color:var(--text)">${s.stage_type}</div>
            <div style="font-size:11px;color:var(--text3)">${s.scheduled_date?new Date(s.scheduled_date).toLocaleDateString('fr-FR',{weekday:'short',day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}):''}</div>
            ${s.notes?`<div style="font-size:11px;color:var(--text2);margin-top:2px">${s.notes}</div>`:''}
          </div>
          <select class="role-select" onchange="updateStageResult(${s.id},this.value)">
            ${['En attente','Positif','Négatif','Annulé'].map(r=>`<option ${s.result===r?'selected':''}>${r}</option>`).join('')}
          </select>
          <button class="btn btn-red btn-sm" onclick="deleteStage(${s.id});this.closest('.stage-item').remove()">✕</button>
        </div>`).join(''):'<div style="color:var(--text3);font-size:12px;padding:8px 0">Aucun entretien planifié</div>'}
    </div>
    <button class="btn btn-secondary btn-sm" style="margin-top:10px" onclick="addStageInline('${id}')">+ Planifier un entretien</button>
  `:'';

  document.getElementById('modal-title').textContent=a?`✏️ ${a.company}`:'+ Nouvelle candidature';
  document.getElementById('modal-body').innerHTML=`
    <div class="row2">
      <div class="fg"><label>Entreprise</label><input id="m-co" value="${a?.company||''}"></div>
      <div class="fg"><label>Poste</label><input id="m-ro" value="${a?.role||''}"></div>
    </div>
    <div class="row2">
      <div class="fg"><label>Date candidature</label><input id="m-dt" type="date" value="${a?.date||td}"></div>
      <div class="fg"><label>Statut</label>
        <select id="m-st">${STATUSES.map(s=>`<option value="${s}"${a?.status===s?' selected':''}>${S_ICON[s]} ${s}</option>`).join('')}</select>
      </div>
    </div>
    <div class="fg"><label>URL de l'annonce <span style="font-size:11px;color:var(--text3);font-weight:400">(optionnel)</span></label><input id="m-url" value="${a?.job_url||''}" placeholder="https://fr.indeed.com/..."></div>
    <div class="fg"><label>Notes</label><textarea id="m-no" rows="2">${a?.notes||''}</textarea></div>
    ${a?.cv_filename?`<div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap">
      <a href="/api/cv-file/${a.cv_filename}" target="_blank" class="btn btn-secondary btn-sm" style="text-decoration:none">👁️ Voir le CV</a>
      <button class="btn btn-primary btn-sm" onclick="downloadCVPdf('${a.cv_filename}')">📥 Télécharger PDF</button>
    </div>`:''}
    ${stagesHTML}`;
  document.getElementById('modal-ft').innerHTML=`
    ${id?`<button class="btn btn-red btn-sm" onclick="delApp('${id}')">🗑</button>`:''}
    <button class="btn btn-secondary" onclick="closeModal()">Annuler</button>
    <button class="btn btn-green" onclick="saveModal('${id||''}')">💾 Sauvegarder</button>`;
  document.getElementById('modal-bg').classList.add('open');
  setTimeout(()=>document.getElementById('m-co').focus(),50);
}

async function addStageInline(appId){
  const list=document.getElementById('modal-stages-list');
  const row=document.createElement('div');
  row.style.cssText='display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:8px;align-items:center;background:var(--card2);border-radius:8px;padding:10px;border:1px solid var(--accent);margin-top:6px';
  row.innerHTML=`
    <select id="ns-type" style="background:var(--surface);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:5px 8px;font-size:12px">${STAGE_TYPES.map(t=>`<option>${t}</option>`).join('')}</select>
    <input type="date" id="ns-date" value="${new Date().toISOString().slice(0,10)}" style="background:var(--surface);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:5px 8px;font-size:12px">
    <input id="ns-notes" placeholder="Notes..." style="background:var(--surface);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:5px 8px;font-size:12px">
    <button class="btn btn-primary btn-sm" onclick="confirmInlineStage('${appId}',this.parentElement)">✓</button>
  `;
  list.appendChild(row);
}

async function confirmInlineStage(appId, rowEl){
  const type=rowEl.querySelector('#ns-type').value;
  const date=rowEl.querySelector('#ns-date').value;
  const notes=rowEl.querySelector('#ns-notes').value;
  const data=await post('/api/interview-stages',{application_id:appId,stage_type:type,scheduled_date:date,notes,result:'En attente'});
  if(data.error){toast(data.error,'error');return;}
  allStages.push(data);
  toast('Entretien ajouté !','success');
  rowEl.innerHTML=`<div style="grid-column:1/-1;font-size:12px;color:var(--green)">✅ ${type} — ${date}</div>`;
}

function closeModal(){document.getElementById('modal-bg').classList.remove('open');}

async function downloadCVPdf(filename){
  toast('Génération du PDF en cours...','info');
  try{
    const resp=await fetch('/api/download-pdf',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({filename})});
    if(!resp.ok){const d=await resp.json();toast(d.error||'Erreur PDF','error');return;}
    const blob=await resp.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url; a.download=filename.replace('.html','.pdf');
    document.body.appendChild(a); a.click();
    setTimeout(()=>{URL.revokeObjectURL(url);document.body.removeChild(a);},1000);
    toast('PDF téléchargé !','success');
  }catch(e){toast('Erreur : '+e.message,'error');}
}

async function saveModal(id){
  const data={
    company:document.getElementById('m-co').value.trim(),
    role:document.getElementById('m-ro').value.trim(),
    date:document.getElementById('m-dt').value,
    interview_date:document.getElementById('m-id').value,
    status:document.getElementById('m-st').value,
    notes:document.getElementById('m-no').value.trim(),
    job_url:document.getElementById('m-url')?.value.trim()||'',
  };
  if(!data.company){toast('Entrez le nom de l\'entreprise','error');return;}
  if(id){
    await put(`/api/applications/${id}`,data);
    const i=apps.findIndex(a=>a.id===id);
    if(i!==-1) apps[i]={...apps[i],...data};
    toast('Candidature mise à jour','success');
  } else {
    const a=await post('/api/applications',data);
    apps.push(a);
    toast('Candidature ajoutée !','success');
    await loadStages(); // planning auto-mis à jour
  }
  closeModal(); renderDash(); renderKanban(); renderAL(); updateBadges();
}

async function delApp(id){
  if(!confirm('Supprimer cette candidature ?')) return;
  await del(`/api/applications/${id}`);
  apps=apps.filter(a=>a.id!==id);
  closeModal(); renderDash(); renderKanban(); renderAL(); updateBadges();
  toast('Supprimée','info');
}

// ── Templates CV — Wizard ──────────────────────────────────────────────────────
let templates=[], tplGeneratedHTML='';

// ── Définition des étapes ──
const WIZ_TOTAL = 5;
let wizStep = 0;
let wizData = { objectif:'', secteur:'', typeEntreprise:'', experience:'', style:'Moderne', tonCV:'', couleur:'#2F5DA8', couleurs:['#2F5DA8','',''], impressions:[] };
let cpActiveSlot = 0;

// ── Color Picker state ──────────────────────────────────────────────────────
let cpH=272, cpS=85, cpV=80; // HSV values for current slot
let cpDrag=null; // 'sq' | 'hue'

function cpHsvToRgb(h,s,v){
  s/=100; v/=100;
  const c=v*s, x=c*(1-Math.abs((h/60)%2-1)), m=v-c;
  let r,g,b;
  if(h<60){r=c;g=x;b=0;}else if(h<120){r=x;g=c;b=0;}
  else if(h<180){r=0;g=c;b=x;}else if(h<240){r=0;g=x;b=c;}
  else if(h<300){r=x;g=0;b=c;}else{r=c;g=0;b=x;}
  return[Math.round((r+m)*255),Math.round((g+m)*255),Math.round((b+m)*255)];
}
function cpHsvToHex(h,s,v){
  return '#'+cpHsvToRgb(h,s,v).map(n=>n.toString(16).padStart(2,'0')).join('');
}
function cpHexToHsv(hex){
  if(!hex||hex.length<7) return {h:0,s:0,v:100};
  const r=parseInt(hex.slice(1,3),16)/255;
  const g=parseInt(hex.slice(3,5),16)/255;
  const b=parseInt(hex.slice(5,7),16)/255;
  const max=Math.max(r,g,b),min=Math.min(r,g,b),d=max-min;
  let h=0,s=max?d/max:0,v=max;
  if(d){
    if(max===r)h=((g-b)/d+(g<b?6:0))*60;
    else if(max===g)h=((b-r)/d+2)*60;
    else h=((r-g)/d+4)*60;
  }
  return{h:Math.round(h),s:Math.round(s*100),v:Math.round(v*100)};
}
function cpUpdateUI(){
  const hueHex=cpHsvToHex(cpH,100,100);
  const sq=document.getElementById('cp-sq');
  const sqHue=document.getElementById('cp-sq-hue');
  const sqCur=document.getElementById('cp-sq-cursor');
  const hueCur=document.getElementById('cp-hue-cursor');
  const hex=document.getElementById('cp-hex');
  const preview=document.getElementById('cp-preview');
  if(!sq) return;
  sqHue.style.background=hueHex;
  const pct=sq.getBoundingClientRect();
  // Cursor position: S = x%, V inverted = y%
  const cx=cpS+'%', cy=(100-cpV)+'%';
  sqCur.style.left=cx; sqCur.style.top=cy;
  hueCur.style.left=(cpH/360*100)+'%';
  const finalHex=cpHsvToHex(cpH,cpS,cpV);
  sqCur.style.background=finalHex;
  if(hex) hex.value=finalHex;
  if(preview) preview.style.background=finalHex;
  // Update slot
  wizData.couleurs[cpActiveSlot]=finalHex;
  wizData.couleur=wizData.couleurs[0]||finalHex;
  const slot=document.getElementById('cp-slot-'+cpActiveSlot);
  if(slot){slot.style.background=finalHex;slot.style.borderColor='';}
  // Update all slot displays
  [0,1,2].forEach(i=>{
    const s=document.getElementById('cp-slot-'+i);
    if(s&&wizData.couleurs[i]) s.style.background=wizData.couleurs[i];
  });
}
function cpClearSlot(i){
  if(i===0) return; // La couleur principale est obligatoire
  wizData.couleurs[i]='';
  if(cpActiveSlot===i) cpActiveSlot=0;
  // Redraw wizard step
  renderWizStep();
}
function cpSetSlot(i){
  cpActiveSlot=i;
  // Load slot color into picker
  const hex=wizData.couleurs[i]||'#2F5DA8';
  const {h,s,v}=cpHexToHsv(hex);
  cpH=h; cpS=s; cpV=v;
  // Update active highlight
  [0,1,2].forEach(j=>{
    const el=document.getElementById('cp-slot-'+j);
    if(el) el.classList.toggle('active',j===i);
  });
  cpUpdateUI();
}
function cpHexInput(val){
  if(!/^#[0-9a-fA-F]{6}$/.test(val)) return;
  const {h,s,v}=cpHexToHsv(val);
  cpH=h; cpS=s; cpV=v;
  cpUpdateUI();
}
function cpSqEvent(e){
  const sq=document.getElementById('cp-sq');
  if(!sq) return;
  const r=sq.getBoundingClientRect();
  const clientX=e.touches?e.touches[0].clientX:e.clientX;
  const clientY=e.touches?e.touches[0].clientY:e.clientY;
  cpS=Math.max(0,Math.min(100,Math.round((clientX-r.left)/r.width*100)));
  cpV=Math.max(0,Math.min(100,Math.round(100-(clientY-r.top)/r.height*100)));
  cpUpdateUI();
}
function cpHueEvent(e){
  const bar=document.getElementById('cp-hue');
  if(!bar) return;
  const r=bar.getBoundingClientRect();
  const clientX=e.touches?e.touches[0].clientX:e.clientX;
  cpH=Math.max(0,Math.min(360,Math.round((clientX-r.left)/r.width*360)));
  cpUpdateUI();
}
function cpInit(){
  // Load current slot color
  const hex=wizData.couleurs[cpActiveSlot]||'#2F5DA8';
  const {h,s,v}=cpHexToHsv(hex);
  cpH=h; cpS=s; cpV=v;
  cpUpdateUI();
  // SV Square events
  const sq=document.getElementById('cp-sq');
  const hue=document.getElementById('cp-hue');
  if(!sq||!hue) return;
  const onSqDown=e=>{cpDrag='sq';cpSqEvent(e);e.preventDefault();};
  const onHueDown=e=>{cpDrag='hue';cpHueEvent(e);e.preventDefault();};
  const onMove=e=>{if(cpDrag==='sq')cpSqEvent(e);else if(cpDrag==='hue')cpHueEvent(e);};
  const onUp=()=>{cpDrag=null;};
  sq.addEventListener('mousedown',onSqDown);
  sq.addEventListener('touchstart',onSqDown,{passive:false});
  hue.addEventListener('mousedown',onHueDown);
  hue.addEventListener('touchstart',onHueDown,{passive:false});
  window.addEventListener('mousemove',onMove);
  window.addEventListener('touchmove',onMove,{passive:false});
  window.addEventListener('mouseup',onUp);
  window.addEventListener('touchend',onUp);
}

function openGenModal(){
  wizStep=0; tplGeneratedHTML=''; cpActiveSlot=0;
  wizData={objectif:'',secteur:'',typeEntreprise:'',experience:'',style:'Moderne',tonCV:'',couleur:'#2F5DA8',couleurs:['#2F5DA8','',''],impressions:[]};
  cpH=272; cpS=85; cpV=80;
  document.getElementById('tpl-gen-overlay').classList.add('open');
  renderWizStep();
}
function closeGenModal(){
  document.getElementById('tpl-gen-overlay').classList.remove('open');
}

function renderWizStep(){
  const prog = document.getElementById('wiz-prog');
  const lbl  = document.getElementById('wiz-step-lbl');
  const body = document.getElementById('wiz-body');
  const foot = document.getElementById('wiz-foot');

  const pct = wizStep===0 ? 0 : Math.round((wizStep/WIZ_TOTAL)*100);
  prog.style.width = pct+'%';
  lbl.textContent  = wizStep===0 ? '' : `Étape ${wizStep} / ${WIZ_TOTAL}`;

  // ── STEP 0 : Hook ──
  if(wizStep===0){
    body.innerHTML=`
      <div class="wiz-hook">
        <div class="wiz-hook-icon">✨</div>
        <div class="wiz-hook-title">Créons un CV qui te correspond vraiment</div>
        <div class="wiz-hook-sub">Réponds à quelques questions (2 min) et on génère un CV sur-mesure, adapté à ton profil et tes ambitions.</div>
      </div>`;
    foot.innerHTML=`<button class="wiz-next" style="width:100%;padding:14px;font-size:15px" onclick="wizNext()">Commencer →</button>`;
    return;
  }

  // ── STEP 1 : Objectif ──
  if(wizStep===1){
    const opts=[
      {i:'🚀',l:'Trouver un job rapidement'},{i:'🎯',l:'Se démarquer visuellement'},
      {i:'🤖',l:'Passer les filtres ATS'},{i:'🧠',l:'Rassurer les recruteurs'},
      {i:'💎',l:'Viser un poste premium'},{i:'🔄',l:'Changer de carrière'}
    ];
    body.innerHTML=`
      <div class="wiz-q-block">
        <div class="wiz-q-title">Quel est ton objectif principal ?</div>
        <div class="wiz-q-sub">Cette réponse guide tout le design de ton CV</div>
        <div class="wiz-opts">
          ${opts.map(o=>`<div class="wiz-opt${wizData.objectif===o.l?' sel':''}" onclick="wizSel(this,'objectif','${o.l.replace(/'/g,"\\'")}')">
            <span class="wiz-opt-icon">${o.i}</span>
            <span class="wiz-opt-label">${o.l}</span>
          </div>`).join('')}
        </div>
      </div>`;
    foot.innerHTML=wizFoot(true);
    return;
  }

  // ── STEP 2 : Contexte ──
  if(wizStep===2){
    const te=['Startup','PME','Grand groupe','Luxe','Restauration','Tech'];
    const exp=['Junior','Confirmé','Senior'];
    body.innerHTML=`
      <div class="wiz-q-block">
        <div class="wiz-q-title">Dans quel secteur cherches-tu ?</div>
        <input class="wiz-input" id="wiz-secteur" placeholder="ex: Tech, Marketing, Finance, Restauration..." value="${wizData.secteur}" oninput="wizData.secteur=this.value" style="margin-top:10px">
      </div>
      <div class="wiz-q-block">
        <div class="wiz-q-title">Quel type d'entreprise vises-tu ?</div>
        <div class="wiz-chips" style="margin-top:10px">
          ${te.map(t=>`<div class="wiz-chip${wizData.typeEntreprise===t?' sel':''}" onclick="wizChip(this,'typeEntreprise','${t}',false)">${t}</div>`).join('')}
        </div>
      </div>
      <div class="wiz-q-block">
        <div class="wiz-q-title">Ton niveau d'expérience ?</div>
        <div class="wiz-chips" style="margin-top:10px">
          ${exp.map(e=>`<div class="wiz-chip${wizData.experience===e?' sel':''}" onclick="wizChip(this,'experience','${e}',false)">${e}</div>`).join('')}
        </div>
      </div>`;
    foot.innerHTML=wizFoot(true);
    return;
  }

  // ── STEP 3 : Style + Couleurs ──
  if(wizStep===3){
    const styles=['Sobre','Moderne','Créatif','Premium','Dynamique'];
    const tons=['Simple','Impactant','Original','Corporate'];
    const slotLabels=['Principale','Secondaire','Accent'];
    body.innerHTML=`
      <div class="wiz-q-block">
        <div class="wiz-q-title">Quel style te correspond ?</div>
        <div class="wiz-chips" style="margin-top:10px">
          ${styles.map(s=>`<div class="wiz-chip${wizData.style===s?' sel':''}" onclick="wizChip(this,'style','${s}',false)">${s}</div>`).join('')}
        </div>
      </div>
      <div class="wiz-q-block">
        <div class="wiz-q-title">Tu veux un CV plutôt :</div>
        <div class="wiz-chips" style="margin-top:10px">
          ${tons.map(t=>`<div class="wiz-chip${wizData.tonCV===t?' sel':''}" onclick="wizChip(this,'tonCV','${t}',false)">${t}</div>`).join('')}
        </div>
      </div>
      <div class="wiz-q-block">
        <div class="wiz-q-title">Ta couleur <span style="font-size:12px;color:var(--text3);font-weight:400">— 1 obligatoire, 2e et 3e optionnelles</span></div>
        <div class="wiz-cp-wrap">
          <!-- Slots -->
          <div class="wiz-cp-slots" id="cp-slots">
            ${wizData.couleurs.map((c,i)=>`
            <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
              <div class="wiz-cp-slot${cpActiveSlot===i?' active':''}" id="cp-slot-${i}"
                   style="background:${c||'var(--card2)'};${!c?'border-style:dashed;border-color:var(--border2)':''}"
                   onclick="cpSetSlot(${i})">
                <span class="wiz-cp-slot-label">${slotLabels[i]}${i===0?' *':''}</span>
                ${!c&&i>0?`<span class="wiz-cp-slot-empty">+</span>`:''}
              </div>
              ${i>0&&c?`<button onclick="cpClearSlot(${i})" style="font-size:10px;background:none;border:none;color:var(--text3);cursor:pointer;padding:0;font-family:'Inter',sans-serif;line-height:1" title="Retirer cette couleur">✕ retirer</button>`:`<span style="font-size:10px;color:var(--text3);opacity:0">&nbsp;</span>`}
            </div>`).join('')}
          </div>
          <!-- SV Square -->
          <div class="wiz-cp-sq-wrap" id="cp-sq">
            <div class="wiz-cp-sq-hue" id="cp-sq-hue"></div>
            <div class="wiz-cp-sq-white"></div>
            <div class="wiz-cp-sq-black"></div>
            <div class="wiz-cp-sq-cursor" id="cp-sq-cursor"></div>
          </div>
          <!-- Hue Slider -->
          <div class="wiz-cp-hue-wrap" id="cp-hue">
            <div class="wiz-cp-hue-cursor" id="cp-hue-cursor"></div>
          </div>
          <!-- Hex -->
          <div class="wiz-cp-hex-row">
            <input class="wiz-cp-hex" id="cp-hex" maxlength="7" placeholder="#2F5DA8" value="${wizData.couleurs[cpActiveSlot]||'#2F5DA8'}" oninput="cpHexInput(this.value)">
            <div class="wiz-cp-preview" id="cp-preview" style="background:${wizData.couleurs[cpActiveSlot]||'#2F5DA8'}"></div>
          </div>
        </div>
      </div>`;
    foot.innerHTML=wizFoot(true);
    // Init picker after DOM is ready
    requestAnimationFrame(()=>cpInit());
    return;
  }

  // ── STEP 4 : Perception ──
  if(wizStep===4){
    const percs=[
      {i:'🎖️',l:'Sérieux'},{i:'⚡',l:'Énergique'},{i:'🤝',l:'Rassurant'},
      {i:'🎨',l:'Créatif'},{i:'💎',l:'Haut de gamme'},{i:'🚀',l:'Innovant'},{i:'📐',l:'Structuré'}
    ];
    body.innerHTML=`
      <div class="wiz-q-block">
        <div class="wiz-q-title">Quelle impression veux-tu donner ?</div>
        <div class="wiz-q-sub">Choisis 2 maximum — c'est la clé de la cohérence visuelle</div>
        <div class="wiz-opts" style="margin-top:10px">
          ${percs.map(p=>`<div class="wiz-opt${wizData.impressions.includes(p.l)?' sel':''}" onclick="wizMulti(this,'${p.l.replace(/'/g,"\\'")}',2)">
            <span class="wiz-opt-icon">${p.i}</span>
            <span class="wiz-opt-label">${p.l}</span>
          </div>`).join('')}
        </div>
      </div>`;
    foot.innerHTML=wizFoot(true);
    return;
  }

  // ── STEP 5 : Confirmation & données ──
  if(wizStep===5){
    // Récupère les données renseignées
    const hasSummary = config && config.has_summary;
    const hasDocs    = config && config.has_docs;
    const hasPhoto   = config && config.has_photo;
    const styleColor = wizData.couleur || '#2F5DA8';
    const styleLabel = wizData.style || 'Moderne';
    const recap = [
      {k:'Objectif',   v:wizData.objectif||'—'},
      {k:'Secteur',    v:wizData.secteur||'—'},
      {k:'Entreprise', v:wizData.typeEntreprise||'—'},
      {k:'Expérience', v:wizData.experience||'—'},
      {k:'Style',      v:styleLabel},
      {k:'Ton',        v:wizData.tonCV||'—'},
      {k:'Impression', v:wizData.impressions.join(', ')||'—'},
    ];
    body.innerHTML=`
      <div class="wiz-q-block">
        <div class="wiz-q-title">Récap &amp; données personnelles</div>
        <div class="wiz-q-sub">Ces informations seront utilisées pour personnaliser ton CV</div>
        ${(!hasSummary && !hasDocs)?`
        <div style="margin:12px 0;padding:14px;background:rgba(234,179,8,.08);border:1px solid var(--yellow);border-radius:10px;display:flex;flex-direction:column;gap:8px">
          <div style="font-size:13px;font-weight:700;color:var(--yellow)">⚠️ Ton profil est vide</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.6">Pour un CV vraiment personnalisé, ajoute ton <strong>résumé personnel</strong> et importe tes <strong>anciens CV ou documents</strong>. Tu peux le faire dans <strong>Paramètres → Profil &amp; Résumé</strong>.</div>
          <button onclick="closeWiz();nav('settings')" style="align-self:flex-start;background:var(--yellow);border:none;color:#fff;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif">→ Aller dans Paramètres</button>
          <div style="font-size:11px;color:var(--text3)">Tu peux quand même générer un CV de base sans profil.</div>
        </div>`:''}
        ${(hasSummary||hasDocs)&&(!hasSummary||!hasDocs)?`
        <div style="margin:10px 0;padding:10px 14px;background:rgba(234,179,8,.06);border:1px solid rgba(234,179,8,.3);border-radius:10px;font-size:12px;color:var(--text2)">
          💡 ${!hasSummary?'Ajoute ton <strong>résumé personnel</strong> dans Paramètres pour enrichir ton CV.':'Importe tes <strong>anciens CV ou documents</strong> dans Paramètres pour de meilleurs résultats.'}
        </div>`:''}


        <!-- Couleur sélectionnée -->
        <div style="display:flex;align-items:center;gap:10px;margin:14px 0 18px;padding:10px 14px;background:var(--card2);border-radius:10px;border:1px solid var(--border)">
          <div style="width:32px;height:32px;border-radius:50%;background:${styleColor};flex-shrink:0;box-shadow:0 2px 10px ${styleColor}55"></div>
          <div>
            <div style="font-size:13px;font-weight:700;color:var(--text)">Style ${styleLabel}</div>
            <div style="font-size:11px;color:var(--text3)">Couleur principale : ${styleColor}</div>
          </div>
        </div>

        <!-- Résumé des choix -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:18px">
          ${recap.map(r=>`
          <div style="padding:8px 10px;background:var(--card2);border-radius:8px;border:1px solid var(--border)">
            <div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:.06em">${r.k}</div>
            <div style="font-size:12px;font-weight:600;color:var(--text);margin-top:2px">${r.v}</div>
          </div>`).join('')}
        </div>

        <!-- Données personnelles -->
        <div style="margin-bottom:14px">
          <div style="font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">📋 Données qui seront utilisées</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--card2);border-radius:8px;border:1px solid ${hasSummary?'var(--green)':'var(--border)'}">
              <span style="font-size:16px">${hasSummary?'✅':'⚠️'}</span>
              <div>
                <div style="font-size:12px;font-weight:600;color:${hasSummary?'var(--green)':'var(--yellow)'}">Résumé personnel</div>
                <div style="font-size:11px;color:var(--text3)">${hasSummary?'Renseigné — le CV sera personnalisé avec ton profil':'Non renseigné — va dans Paramètres pour un meilleur résultat'}</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--card2);border-radius:8px;border:1px solid ${hasDocs?'var(--green)':'var(--border)'}">
              <span style="font-size:16px">${hasDocs?'✅':'⚠️'}</span>
              <div>
                <div style="font-size:12px;font-weight:600;color:${hasDocs?'var(--green)':'var(--text2)'}">Documents importés</div>
                <div style="font-size:11px;color:var(--text3)">${hasDocs?'Anciens CV / LinkedIn disponibles':'Non importés'}</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--card2);border-radius:8px;border:1px solid ${hasPhoto?'var(--green)':'var(--border)'}">
              <span style="font-size:16px">${hasPhoto?'✅':'⚠️'}</span>
              <div>
                <div style="font-size:12px;font-weight:600;color:${hasPhoto?'var(--green)':'var(--text2)'}">Photo de profil</div>
                <div style="font-size:11px;color:var(--text3)">${hasPhoto?'Photo disponible — sera intégrée automatiquement':'Aucune photo'}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Nom du template -->
        <div>
          <div style="font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">Nom du template</div>
          <input class="wiz-input" id="wiz-tpl-name" placeholder="ex: Mon CV Créatif Tech" value="${wizData.tplName||''}" oninput="wizData.tplName=this.value">
        </div>
      </div>`;
    foot.innerHTML=`
      ${wizBack()}
      <button class="wiz-next" onclick="generateTemplate()" style="background:linear-gradient(135deg,var(--accent),var(--purple));padding:10px 22px">✨ Générer mon CV</button>`;
    return;
  }
}

function wizFoot(hasBack){
  return `${hasBack?wizBack():''}<button class="wiz-next" onclick="wizNext()">Continuer →</button>`;
}
function wizBack(){
  return `<button class="wiz-back" onclick="wizPrev()">← Retour</button>`;
}
function wizNext(){
  if(wizStep===0){wizStep=1;renderWizStep();return;}
  // Validations légères
  if(wizStep===1 && !wizData.objectif){toast('Choisis un objectif','error');return;}
  if(wizStep===2 && !wizData.secteur.trim()){document.getElementById('wiz-secteur')?.focus();toast('Indique ton secteur','error');return;}
  wizStep++; renderWizStep();
}
function wizPrev(){ if(wizStep>0){wizStep--;renderWizStep();} }

function wizSel(el, key, val){
  wizData[key]=val;
  el.closest('.wiz-opts').querySelectorAll('.wiz-opt').forEach(o=>o.classList.remove('sel'));
  el.classList.add('sel');
}
function wizChip(el, key, val, multi){
  if(!multi){
    wizData[key]=val;
    el.closest('.wiz-chips').querySelectorAll('.wiz-chip').forEach(c=>c.classList.remove('sel'));
    el.classList.add('sel');
  }
}
function wizColor(el, val){
  // legacy — remplacé par le color picker custom
  wizData.couleur=val; wizData.couleurs[0]=val;
}
function wizMulti(el, val, max){
  const idx=wizData.impressions.indexOf(val);
  if(idx!==-1){ wizData.impressions.splice(idx,1); el.classList.remove('sel'); return; }
  if(wizData.impressions.length>=max){ toast(`Maximum ${max} choix`,'error'); return; }
  wizData.impressions.push(val); el.classList.add('sel');
}

// ── Génération ──
async function generateTemplate(){
  if(!wizData.impressions.length){toast('Choisis au moins une impression','error');return;}

  // Lit explicitement les inputs DOM
  const secteurEl  = document.getElementById('wiz-secteur');
  const tplNameEl  = document.getElementById('wiz-tpl-name');
  if(secteurEl)  wizData.secteur  = secteurEl.value.trim();
  if(tplNameEl)  wizData.tplName  = tplNameEl.value.trim();

  // Normalise le style (Dynamique → Impactant pour le backend)
  const styleMap = {'Dynamique':'Impactant'};
  const styleNorm = styleMap[wizData.style] || wizData.style || 'Moderne';

  const name = wizData.tplName || `CV ${styleNorm} ${wizData.secteur||wizData.typeEntreprise||''}`.trim() || 'Mon CV';

  // Messages de génération rotatifs
  const msgs = [
    'Analyse de ton profil...',
    'Design du layout en cours...',
    'Choix de la typographie...',
    'Construction des sections...',
    'Peaufinage des détails visuels...',
    'Finalisation de ton CV...'
  ];
  let mi = 0;
  const prog = document.getElementById('wiz-prog');
  if(prog) prog.style.width='100%';

  document.getElementById('wiz-body').innerHTML=`
    <div class="wiz-generating">
      <div class="wiz-gen-spin"></div>
      <div style="font-size:16px;font-weight:700;color:var(--text)" id="wiz-gen-msg">Analyse de ton profil...</div>
      <div style="font-size:13px;color:var(--text2);text-align:center">Conception de ton CV sur-mesure</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:12px">
        <span style="padding:4px 10px;background:var(--accent-glow);border:1px solid var(--accent);border-radius:20px;font-size:11px;font-weight:600;color:var(--accent)">✨ ${styleNorm}</span>
        ${wizData.secteur?`<span style="padding:4px 10px;background:var(--card2);border:1px solid var(--border2);border-radius:20px;font-size:11px;color:var(--text2)">${wizData.secteur}</span>`:''}
        ${wizData.typeEntreprise?`<span style="padding:4px 10px;background:var(--card2);border:1px solid var(--border2);border-radius:20px;font-size:11px;color:var(--text2)">${wizData.typeEntreprise}</span>`:''}
      </div>
    </div>`;
  document.getElementById('wiz-foot').innerHTML='';

  const msgInterval = setInterval(()=>{
    mi=(mi+1)%msgs.length;
    const el=document.getElementById('wiz-gen-msg');
    if(el) el.textContent=msgs[mi];
  }, 2200);

  // Envoie TOUTES les réponses + style normalisé + palette 3 couleurs
  const couleursFiltered = wizData.couleurs.filter(c=>c&&c.length===7);
  const payload = {
    objectif:       wizData.objectif,
    secteur:        wizData.secteur,
    typeEntreprise: wizData.typeEntreprise,
    experience:     wizData.experience,
    style:          styleNorm,
    tonCV:          wizData.tonCV,
    couleur:        couleursFiltered[0] || wizData.couleur || '#2F5DA8',
    couleurs:       couleursFiltered,
    impressions:    wizData.impressions,
    name:           name
  };

  let data;
  try {
    data = await post('/api/generate-template', payload);
  } finally {
    clearInterval(msgInterval);
  }

  if(data.error){
    toast('Erreur : '+data.error,'error');
    wizStep=5; renderWizStep(); return;
  }
  tplGeneratedHTML=data.html;

  // Écran résultat avec preview iframe
  document.getElementById('wiz-body').innerHTML=`
    <div style="border-radius:12px;overflow:hidden;border:2px solid var(--accent);box-shadow:0 0 30px var(--accent-glow)">
      <div style="padding:10px 14px;background:var(--card2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px">
        <div style="width:10px;height:10px;border-radius:50%;background:var(--red)"></div>
        <div style="width:10px;height:10px;border-radius:50%;background:var(--yellow)"></div>
        <div style="width:10px;height:10px;border-radius:50%;background:var(--green)"></div>
        <span style="font-size:11px;color:var(--text3);margin-left:6px">Aperçu — ${name}</span>
      </div>
      <div style="height:460px;background:#fff;overflow:auto">
        <iframe id="wiz-preview-frame" style="width:100%;height:100%;border:none;display:block" scrolling="yes"></iframe>
      </div>
    </div>`;
  document.getElementById('wiz-preview-frame').srcdoc=tplGeneratedHTML;
  const safeName=name.replace(/'/g,"\\'");
  document.getElementById('wiz-foot').innerHTML=`
    <button class="wiz-back" onclick="wizStep=5;renderWizStep()">← Modifier</button>
    <button class="btn btn-secondary btn-sm" onclick="downloadWizPdf('${safeName}')">📥 PDF</button>
    <button class="wiz-next" onclick="saveWizTemplate('${safeName}')">💾 Sauvegarder</button>`;
  toast('✨ Template généré !','success');
}

async function saveWizTemplate(name){
  const data=await post('/api/cv-templates',{
    name, style:wizData.style||'Moderne', color:wizData.couleur, html:tplGeneratedHTML
  });
  if(data.error){toast(data.error,'error');return;}
  templates.unshift(data);
  toast('Template sauvegardé !','success');
  closeGenModal(); renderTemplates();
}

async function downloadWizPdf(name){
  if(!tplGeneratedHTML){return;}
  toast('Génération PDF...','info');
  try{
    const resp=await fetch('/api/preview-pdf',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({html:tplGeneratedHTML,name})});
    if(!resp.ok){const d=await resp.json();toast(d.error||'Erreur PDF','error');return;}
    const blob=await resp.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=name+'.pdf';
    document.body.appendChild(a); a.click();
    setTimeout(()=>{URL.revokeObjectURL(url);document.body.removeChild(a);},1000);
    toast('PDF téléchargé !','success');
  }catch(e){toast('Erreur : '+e.message,'error');}
}

async function downloadTplPdf(id, name){
  toast('Génération PDF...','info');
  try{
    const resp=await fetch(`/api/template-pdf/${id}`);
    if(!resp.ok){const d=await resp.json();toast(d.error||'Erreur PDF','error');return;}
    const blob=await resp.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=(name||'template')+'.pdf';
    document.body.appendChild(a); a.click();
    setTimeout(()=>{URL.revokeObjectURL(url);document.body.removeChild(a);},1000);
    toast('PDF téléchargé !','success');
  }catch(e){toast('Erreur : '+e.message,'error');}
}

async function previewTpl(id){
  const data=await api(`/api/cv-templates/${id}`);
  if(data.error){toast(data.error,'error');return;}
  tplGeneratedHTML=data.html_content;
  // Mode preview direct
  document.getElementById('tpl-gen-overlay').classList.add('open');
  document.getElementById('wiz-prog').style.width='100%';
  document.getElementById('wiz-step-lbl').textContent='Aperçu';
  document.getElementById('wiz-body').innerHTML=`
    <div style="height:420px;background:var(--surface);border-radius:12px;overflow:hidden;border:1px solid var(--border)">
      <iframe style="width:100%;height:100%;border:none" srcdoc="${data.html_content.replace(/"/g,'&quot;')}"></iframe>
    </div>`;
  document.getElementById('wiz-foot').innerHTML=`
    <button class="wiz-back" onclick="closeGenModal()">✕ Fermer</button>
    <button class="btn btn-secondary" onclick="downloadTplPdf(${id},'${(data.name||'').replace(/'/g,"\\'")}')">📥 PDF</button>`;
}

async function deleteTpl(id){
  if(!confirm('Supprimer ce template ?')) return;
  await del(`/api/cv-templates/${id}`);
  templates=templates.filter(t=>t.id!==id);
  renderTemplates(); toast('Template supprimé','info');
}

async function loadTemplates(){
  templates=await api('/api/cv-templates');
  renderTemplates();
}

function renderTemplates(){
  const grid=document.getElementById('tpl-grid');
  if(!templates.length){
    grid.innerHTML=`<div class="tpl-empty-state">
      <div style="font-size:48px">🎨</div>
      <div style="font-size:15px;font-weight:600;color:var(--text2)">Aucun template</div>
      <div style="font-size:13px">Répondez à quelques questions et on crée votre CV sur-mesure</div>
      <button class="btn btn-primary" onclick="openGenModal()">✨ Créer mon CV</button>
    </div>`; return;
  }
  grid.innerHTML=templates.map(t=>`
    <div class="tpl-card">
      <div class="tpl-thumb" onclick="previewTpl(${t.id})">
        <iframe srcdoc="" data-tpl-id="${t.id}" loading="lazy"></iframe>
        <div class="tpl-thumb-overlay"><span style="color:#fff;font-size:13px;font-weight:600">👁️ Aperçu</span></div>
      </div>
      <div class="tpl-info">
        <div class="tpl-name">${t.name}</div>
        <div class="tpl-meta">
          <div class="tpl-dot" style="background:${t.color||'#2F5DA8'}"></div>
          <span>${t.style||'Moderne'}</span>
          <span style="margin-left:auto">${(t.created_at||'').slice(0,10)}</span>
        </div>
        <div class="tpl-actions">
          <button class="tpl-btn primary" onclick="downloadTplPdf(${t.id},'${(t.name||'').replace(/'/g,"\\'")}')">📥 PDF</button>
          <button class="tpl-btn" onclick="previewTpl(${t.id})">👁️</button>
          <button class="tpl-btn danger" onclick="deleteTpl(${t.id})">🗑</button>
        </div>
      </div>
    </div>`).join('');
  grid.querySelectorAll('iframe[data-tpl-id]').forEach(async iframe=>{
    const id=iframe.dataset.tplId;
    const d=await api(`/api/cv-templates/${id}`);
    if(d.html_content) iframe.srcdoc=d.html_content;
  });
}

/* ── Sidebar mobile toggle ── */
function toggleSidebar(){
  const sb=document.getElementById('sidebar');
  if(sb.classList.contains('open')) closeSidebar();
  else openSidebar();
}
function openSidebar(){
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('sidebar-backdrop').classList.add('show');
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-backdrop').classList.remove('show');
}

/* Scroll bottom nav to show active tab */
function syncBottomNav(id){
  const btn=document.querySelector(`#bottom-nav .bn-btn[data-page="${id}"]`);
  if(btn) btn.scrollIntoView({inline:'center',behavior:'smooth'});
}
</script>
</body>
</html>
