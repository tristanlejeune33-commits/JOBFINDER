<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JobFinder — Le copilote de ta recherche d'emploi</title>

<!-- ══ Favicon & PWA Icons ══ -->
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%232F5DA8'/%3E%3Cpath d='M6 13Q6 11 8 11H24Q26 11 26 13V22Q26 24 24 24H18L16 27L14 24H8Q6 24 6 22Z' fill='white'/%3E%3Cpath d='M13 11V10Q13 9 14 9H18Q19 9 19 10V11' fill='none' stroke='white' stroke-width='1.5' stroke-linecap='round'/%3E%3Ccircle cx='16' cy='17' r='4' fill='%235BB98C'/%3E%3Ccircle cx='16' cy='17' r='2.2' fill='white'/%3E%3Ccircle cx='16' cy='17' r='0.9' fill='%235BB98C'/%3E%3C/svg%3E">
<link rel="icon" sizes="32x32" type="image/png" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%232F5DA8'/%3E%3Cpath d='M6 13Q6 11 8 11H24Q26 11 26 13V22Q26 24 24 24H18L16 27L14 24H8Q6 24 6 22Z' fill='white'/%3E%3Cpath d='M13 11V10Q13 9 14 9H18Q19 9 19 10V11' fill='none' stroke='white' stroke-width='1.5' stroke-linecap='round'/%3E%3Ccircle cx='16' cy='17' r='4' fill='%235BB98C'/%3E%3Ccircle cx='16' cy='17' r='2.2' fill='white'/%3E%3Ccircle cx='16' cy='17' r='0.9' fill='%235BB98C'/%3E%3C/svg%3E">
<link rel="apple-touch-icon" sizes="180x180" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'%3E%3Crect width='180' height='180' rx='40' fill='%232F5DA8'/%3E%3Cpath d='M34 74Q34 62 46 62H134Q146 62 146 74V125Q146 137 134 137H100L90 152L80 137H46Q34 137 34 125Z' fill='white'/%3E%3Cpath d='M72 62V56Q72 50 78 50H102Q108 50 108 56V62' fill='none' stroke='white' stroke-width='8' stroke-linecap='round'/%3E%3Ccircle cx='90' cy='98' r='22' fill='%235BB98C'/%3E%3Ccircle cx='90' cy='98' r='12' fill='white'/%3E%3Ccircle cx='90' cy='98' r='5' fill='%235BB98C'/%3E%3Cline x1='62' y1='98' x2='74' y2='98' stroke='white' stroke-width='5'/%3E%3Cline x1='106' y1='98' x2='118' y2='98' stroke='white' stroke-width='5'/%3E%3Cline x1='90' y1='70' x2='90' y2='82' stroke='white' stroke-width='5'/%3E%3Cline x1='90' y1='114' x2='90' y2='126' stroke='white' stroke-width='5'/%3E%3C/svg%3E">
<meta name="theme-color" content="#2F5DA8">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="JobFinder">
<meta property="og:title" content="JobFinder — Le copilote de ta recherche d'emploi">
<meta property="og:description" content="Trouve, adapte et suis tes candidatures avec JobFinder.">
<meta property="og:type" content="website">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  /* ── Palette principale — Bleu Confiance ── */
  --bg:#EEF3FB;
  --surface:#FFFFFF;
  --card:#FFFFFF;
  --card2:#F4F7FD;
  --border:#E2EAF4;
  --border2:#C8D6EC;

  /* Bleu premium (accent) */
  --accent:#2F5DA8;
  --accent2:#1E3A5F;
  --accent-glow:rgba(47,93,168,.1);
  --accent-light:#EBF1FB;

  /* Couleurs sémantiques */
  --green:#5BB98C;
  --green-d:rgba(91,185,140,.12);
  --yellow:#E89B1A;
  --yellow-d:rgba(232,155,26,.1);
  --red:#E0453A;
  --red-d:rgba(224,69,58,.1);
  --blue:#4F7CAC;
  --blue-d:rgba(79,124,172,.1);
  --purple:#7A8FBF;
  --purple-d:rgba(122,143,191,.1);

  /* Texte */
  --text:#1E3A5F;
  --text2:#6B7280;
  --text3:#9CA3AF;

  /* Arrondis */
  --radius:14px;--radius-sm:9px;--radius-xs:6px;

  /* Ombres douces (thème clair) */
  --shadow:0 1px 3px rgba(30,58,95,.06),0 4px 16px rgba(30,58,95,.07);
  --shadow-md:0 2px 8px rgba(30,58,95,.09),0 8px 28px rgba(30,58,95,.09);
  --shadow-lg:0 4px 20px rgba(30,58,95,.11),0 16px 48px rgba(30,58,95,.11);
  --t:all .18s ease;
  --gradient-primary:linear-gradient(135deg,#3a6cc0,#2F5DA8);
}
html,body{
  height:100%;font-family:'Inter',sans-serif;
  background:var(--bg);color:var(--text);overflow:hidden;
  -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;
}
#app{display:flex;height:100vh}

/* ══════════════════════════════════════════════════════
   AUTH — Split-screen layout
   ══════════════════════════════════════════════════════ */
#auth-overlay{
  position:fixed;inset:0;z-index:9999;
  display:flex;align-items:stretch;
  background:#0f1f3d;
  overflow:hidden;
}

/* ── LEFT panel (marketing) ── */
.auth-left{
  flex:1;min-width:0;
  background:linear-gradient(145deg,#0f1f3d 0%,#1a3461 45%,#0f2b50 100%);
  display:flex;flex-direction:column;justify-content:center;
  padding:52px 56px;position:relative;overflow:hidden;
}
/* Mesh gradient orbs */
.auth-left::before{
  content:'';position:absolute;width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(47,93,168,.25) 0%,transparent 65%);
  top:-150px;right:-200px;pointer-events:none;
}
.auth-left::after{
  content:'';position:absolute;width:450px;height:450px;border-radius:50%;
  background:radial-gradient(circle,rgba(91,185,140,.12) 0%,transparent 65%);
  bottom:-120px;left:-100px;pointer-events:none;
}
/* Floating dots grid (decorative) */
.auth-dots{
  position:absolute;inset:0;pointer-events:none;
  background-image:radial-gradient(rgba(255,255,255,.06) 1px,transparent 1px);
  background-size:28px 28px;
}
.auth-brand{display:flex;align-items:center;gap:12px;margin-bottom:40px;position:relative;z-index:1}
.auth-brand-icon{
  width:48px;height:48px;border-radius:14px;
  background:linear-gradient(135deg,#3a6cc0,#2F5DA8);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 6px 20px rgba(47,93,168,.5);
  flex-shrink:0;
}
.auth-brand h1{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.4px}
.auth-headline{position:relative;z-index:1;margin-bottom:18px}
.auth-headline h2{
  font-size:32px;font-weight:800;color:#fff;line-height:1.22;letter-spacing:-.6px;
  margin-bottom:12px;
}
.auth-headline h2 em{
  font-style:normal;
  background:linear-gradient(135deg,#5BB98C,#34d399);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.auth-headline p{font-size:14px;color:rgba(255,255,255,.58);line-height:1.7;max-width:380px;font-weight:400}

/* Flow illustration */
.auth-flow{
  display:flex;align-items:center;gap:10px;margin:24px 0;position:relative;z-index:1;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);
  border-radius:14px;padding:16px 18px;backdrop-filter:blur(4px);
}
.auth-flow-box{
  flex:1;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);
  border-radius:10px;padding:10px 12px;
}
.auth-flow-label{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:6px}
.auth-flow-lines{display:flex;flex-direction:column;gap:4px}
.auth-flow-line{height:6px;border-radius:3px;background:rgba(255,255,255,.12)}
.auth-flow-line:nth-child(1){width:80%}
.auth-flow-line:nth-child(2){width:60%}
.auth-flow-line:nth-child(3){width:70%}
.auth-flow-arrow{font-size:20px;color:rgba(47,93,168,.9);flex-shrink:0;filter:drop-shadow(0 0 6px rgba(47,93,168,.7))}
.auth-flow-orb{
  width:52px;height:52px;border-radius:50%;flex-shrink:0;
  background:radial-gradient(circle,#3a6cc0,#2F5DA8);
  display:flex;align-items:center;justify-content:center;font-size:22px;
  box-shadow:0 0 22px rgba(47,93,168,.7),0 0 50px rgba(47,93,168,.3);
  animation:orbPulse 2.5s ease-in-out infinite;
}
@keyframes orbPulse{
  0%,100%{box-shadow:0 0 22px rgba(47,93,168,.7),0 0 50px rgba(47,93,168,.3)}
  50%{box-shadow:0 0 32px rgba(47,93,168,.9),0 0 70px rgba(47,93,168,.5)}
}
.auth-flow-cv{flex:1;background:rgba(255,255,255,.96);border-radius:10px;padding:10px 12px}
.auth-flow-cv-head{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.auth-flow-cv-avatar{width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,#3a6cc0,#2F5DA8)}
.auth-flow-cv-ats{font-size:9px;font-weight:800;background:#5BB98C;color:#fff;padding:2px 5px;border-radius:4px;letter-spacing:.04em}
.auth-flow-cv-lines{display:flex;flex-direction:column;gap:3px}
.auth-flow-cv-line{height:5px;border-radius:3px;background:#e2eaf4}
.auth-flow-cv-line:nth-child(1){width:85%}
.auth-flow-cv-line:nth-child(2){width:65%}
.auth-flow-cv-check{font-size:10px;font-weight:700;color:#5BB98C;margin-top:6px}

/* Stats grid */
.auth-stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:8px;
  margin-bottom:22px;position:relative;z-index:1;
}
.auth-stat{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  border-radius:12px;padding:14px 10px;text-align:center;
  transition:transform .2s,background .2s;
  opacity:0;transform:translateY(20px);
}
.auth-stat.visible{opacity:1;transform:translateY(0)}
.auth-stat:hover{background:rgba(255,255,255,.1);transform:translateY(-2px)}
.auth-stat-icon{font-size:18px;margin-bottom:6px;display:block}
.auth-stat-num{
  font-size:18px;font-weight:800;color:#fff;letter-spacing:-.5px;line-height:1;
  display:flex;justify-content:center;align-items:baseline;gap:1px;
}
.auth-stat-num .prefix{font-size:14px;font-weight:700;color:rgba(255,255,255,.7)}
.auth-stat-num .suffix{font-size:12px;font-weight:700;color:rgba(255,255,255,.7);margin-left:1px}
.auth-stat-label{font-size:10px;color:rgba(255,255,255,.45);margin-top:4px;font-weight:500;line-height:1.3}

/* Odometer / slot roll animation */
.odo-wrap{display:inline-flex;overflow:hidden;height:22px;align-items:flex-end}
.odo-digit{
  display:flex;flex-direction:column;
  transition:transform .6s cubic-bezier(.22,.61,.36,1);
  will-change:transform;
}
.odo-digit span{height:22px;display:flex;align-items:center;justify-content:center;line-height:1}

/* Social proof */
.auth-social{
  display:flex;align-items:center;gap:12px;position:relative;z-index:1;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);
  border-radius:12px;padding:12px 16px;
  opacity:0;transform:translateY(16px);transition:all .5s ease .8s;
}
.auth-social.visible{opacity:1;transform:translateY(0)}
.auth-social-avatars{display:flex}
.auth-social-av{
  width:28px;height:28px;border-radius:50%;border:2px solid rgba(15,31,61,1);
  background:linear-gradient(135deg,#3a6cc0,#5BB98C);
  margin-left:-8px;font-size:11px;font-weight:700;color:#fff;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.auth-social-av:first-child{margin-left:0}
.auth-social-stars{color:#f59e0b;font-size:12px;letter-spacing:1px;line-height:1}
.auth-social-text{font-size:11.5px;color:rgba(255,255,255,.65);line-height:1.4}
.auth-social-text strong{color:rgba(255,255,255,.9);font-weight:700}

/* Feature pill */
.auth-feature{
  display:flex;align-items:center;gap:12px;margin-top:14px;
  background:linear-gradient(135deg,rgba(91,185,140,.1),rgba(91,185,140,.06));
  border:1px solid rgba(91,185,140,.25);border-radius:12px;padding:12px 16px;
  position:relative;z-index:1;
  opacity:0;transform:translateY(16px);transition:all .5s ease 1s;
}
.auth-feature.visible{opacity:1;transform:translateY(0)}
.auth-feature-icon{font-size:22px;flex-shrink:0}
.auth-feature-text{font-size:12px;color:rgba(255,255,255,.65);line-height:1.5}
.auth-feature-text strong{color:#5BB98C;font-weight:700}
.auth-feature-badge{
  flex-shrink:0;width:36px;height:36px;border-radius:50%;
  background:rgba(91,185,140,.2);border:1px solid rgba(91,185,140,.35);
  display:flex;align-items:center;justify-content:center;font-size:18px;
}

/* ── RIGHT panel (form) ── */
.auth-right{
  width:420px;flex-shrink:0;
  background:#fff;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:48px 44px;
  box-shadow:-20px 0 60px rgba(0,0,0,.2);
  overflow-y:auto;
}
.auth-box{
  width:100%;max-width:340px;
  animation:mIn .3s cubic-bezier(.34,1.56,.64,1);
}
.auth-logo{display:flex;align-items:center;gap:12px;margin-bottom:6px;justify-content:center}
.auth-logo-icon{
  width:42px;height:42px;border-radius:12px;
  background:linear-gradient(135deg,#3a6cc0,#2F5DA8);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(47,93,168,.35);
}
.auth-logo h2{font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px}
.auth-tagline{text-align:center;font-size:12.5px;color:var(--text2);margin-bottom:28px;font-weight:400}
.auth-tabs{
  display:flex;background:var(--card2);border-radius:10px;padding:4px;margin-bottom:22px;
  border:1px solid var(--border);
}
.auth-tab{flex:1;padding:8px;text-align:center;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;color:var(--text2);transition:var(--t)}
.auth-tab.active{
  background:linear-gradient(135deg,#3a6cc0,#2F5DA8);color:#fff;
  box-shadow:0 2px 8px rgba(47,93,168,.3);
}
.auth-error{color:var(--red);font-size:12px;margin-top:8px;display:none;background:var(--red-d);padding:8px 12px;border-radius:8px;border:1px solid rgba(224,69,58,.2)}
.auth-divider{display:flex;align-items:center;gap:10px;margin:16px 0;color:var(--text3);font-size:12px}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.auth-trust{display:flex;justify-content:center;gap:16px;margin-top:18px;flex-wrap:wrap}
.auth-trust-item{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:5px}
.auth-trust-item span{font-size:13px}

/* ── Planning calendrier ── */
.planning-filters{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.plan-pill{
  padding:6px 16px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;
  border:1.5px solid var(--border);background:var(--card);color:var(--text2);
  transition:var(--t);font-family:'Inter',sans-serif;
  box-shadow:0 1px 2px rgba(30,58,95,.04);
}
.plan-pill:hover{color:var(--text);border-color:var(--border2);background:var(--card2)}
.plan-pill.active{background:linear-gradient(135deg,#3a6cc0,#2F5DA8);border-color:var(--accent);color:#fff;box-shadow:0 2px 8px rgba(47,93,168,.25)}
.plan-pill.pill-wait.active{background:var(--yellow);border-color:var(--yellow);color:#fff;box-shadow:0 2px 8px rgba(232,155,26,.25)}
.plan-pill.pill-interview.active{background:var(--blue);border-color:var(--blue);color:#fff;box-shadow:0 2px 8px rgba(79,124,172,.25)}
.plan-pill.pill-sent.active{background:var(--green);border-color:var(--green);color:#fff;box-shadow:0 2px 8px rgba(91,185,140,.25)}
.plan-search{
  background:var(--card);border:1.5px solid var(--border);color:var(--text);
  border-radius:20px;padding:6px 14px;font-size:12px;outline:none;
  margin-left:auto;width:180px;font-family:'Inter',sans-serif;
  transition:border-color .18s,box-shadow .18s;
}
.plan-search:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(47,93,168,.1)}
.plan-search::placeholder{color:var(--text3)}
/* nav */
.cal-nav{
  display:flex;align-items:center;gap:10px;margin-bottom:14px;
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:10px 16px;box-shadow:var(--shadow);
}
.cal-nav-arrow{
  background:var(--card2);border:1px solid var(--border);color:var(--text);
  border-radius:8px;width:32px;height:32px;font-size:16px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:var(--t);
  font-family:'Inter',sans-serif;font-weight:600;
}
.cal-nav-arrow:hover{background:var(--accent-light);border-color:var(--accent);color:var(--accent)}
.cal-title-wrap{flex:1;text-align:center}
.cal-title{font-size:15px;font-weight:700;color:var(--text);text-transform:capitalize}
.cal-today-btn{font-size:11px;color:var(--text3);background:none;border:none;cursor:pointer;padding:2px 6px;border-radius:6px;transition:var(--t);font-family:'Inter',sans-serif}
.cal-today-btn:hover{background:var(--card2);color:var(--text)}
.cal-view-toggle{display:flex;background:var(--card2);border-radius:8px;padding:3px;gap:2px}
.cal-view-btn{padding:5px 12px;border-radius:6px;border:none;background:none;color:var(--text2);font-size:12px;font-weight:600;cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif}
.cal-view-btn.active{background:var(--accent);color:#fff}
/* 7 jours */
.cal-7{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
.cal-day-col{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;min-height:140px;display:flex;flex-direction:column}
.cal-day-col.cal-today{border-color:var(--accent)}
.cal-day-hdr{padding:8px 10px;border-bottom:1px solid var(--border);text-align:center;flex-shrink:0}
.cal-day-name{font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:700;letter-spacing:.06em}
.cal-day-num{font-size:22px;font-weight:800;color:var(--text);line-height:1.1;margin-top:2px}
.cal-day-col.cal-today .cal-day-num{color:var(--accent)}
.cal-day-events{padding:6px;display:flex;flex-direction:column;gap:4px;flex:1}
.cal-ev{padding:5px 7px;border-radius:6px;font-size:11px;cursor:pointer;transition:opacity .15s;border-left:2px solid transparent}
.cal-ev:hover{opacity:.75}
.cal-ev-time{font-size:10px;font-weight:700;line-height:1}
.cal-ev-co{font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:11px}
.cal-ev-type{color:var(--text2);font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
/* 30 jours */
.cal-30{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-30-hdr{text-align:center;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;padding:6px 0;letter-spacing:.06em}
.cal-30-cell{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:6px 7px;min-height:78px;cursor:default}
.cal-30-cell.cal-today{border-color:var(--accent)}
.cal-30-cell.other-month{opacity:.28;pointer-events:none}
.cal-30-num{font-size:12px;font-weight:700;color:var(--text2);margin-bottom:4px}
.cal-30-cell.cal-today .cal-30-num{color:var(--accent)}
.cal-30-ev{font-size:10px;font-weight:600;padding:2px 5px;border-radius:4px;border-left:2px solid transparent;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
.cal-30-more{font-size:10px;color:var(--text3);padding-left:4px;cursor:pointer}
.planning-empty{text-align:center;padding:60px 20px;color:var(--text3)}

/* ── Stages dans modal ── */
.stages-list{display:flex;flex-direction:column;gap:8px;margin-top:10px}
.stage-item{display:grid;grid-template-columns:1fr auto auto auto;gap:8px;align-items:center;background:var(--card2);border-radius:var(--radius-sm);padding:10px 12px;border:1px solid var(--border)}
.stage-item select,.stage-item input{background:var(--surface);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:5px 8px;font-size:12px}

/* ── Admin ── */
.admin-table th,.admin-table td{padding:10px 14px;font-size:13px}
.role-select{background:var(--card2);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:4px 8px;font-size:12px}
.role-badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700}
.rb-admin{background:var(--red-d);color:var(--red)}
.rb-pro{background:var(--purple-d);color:var(--purple)}
.rb-membre{background:var(--card2);color:var(--text2)}

/* ── Sidebar ── */
#sidebar{
  width:218px;min-width:218px;
  background:linear-gradient(180deg,#223f6b 0%,#1a3054 55%,#142746 100%);
  border-right:none;
  display:flex;flex-direction:column;z-index:100;
  box-shadow:2px 0 20px rgba(14,28,56,.3);
}
.s-logo{padding:22px 18px 16px;border-bottom:1px solid rgba(255,255,255,.08)}
.s-logo-mark{display:flex;align-items:center;gap:11px;margin-bottom:5px}
.s-logo-icon{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,rgba(79,124,172,.6),rgba(47,93,168,.4));
  border:1px solid rgba(255,255,255,.18);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  box-shadow:0 2px 12px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.12);
}
.s-logo-mark h1{font-size:15.5px;font-weight:800;color:#fff;letter-spacing:-.3px}
.s-logo p{font-size:10.5px;color:rgba(255,255,255,.38);padding-left:47px;line-height:1.3}
.s-nav{padding:8px 10px;flex:1}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;border-radius:var(--radius-sm);margin-bottom:2px;
  color:rgba(255,255,255,.5);font-size:12.5px;font-weight:500;cursor:pointer;transition:var(--t);
  position:relative;user-select:none;border:1px solid transparent;
  overflow:hidden;
}
.nav-item:hover{background:rgba(255,255,255,.08);color:rgba(255,255,255,.88)}
.nav-item.active{
  background:rgba(255,255,255,.12);color:#fff;
  border-color:rgba(255,255,255,.14);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}
.nav-item.active::before{
  content:'';position:absolute;left:0;top:20%;bottom:20%;
  width:3px;border-radius:0 3px 3px 0;
  background:linear-gradient(to bottom,rgba(255,255,255,.9),rgba(255,255,255,.5));
  box-shadow:0 0 6px rgba(255,255,255,.4);
}
.nav-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0;transition:transform .18s;line-height:1}
.nav-item:hover .nav-icon{transform:scale(1.12)}
.nav-label{display:flex;flex-direction:column;gap:1px;min-width:0}
.nav-label-main{font-size:12.5px;font-weight:600;color:inherit;white-space:nowrap}
.nav-label-sub{font-size:10px;color:rgba(255,255,255,.32);font-weight:400;white-space:nowrap;line-height:1.2}
.nav-item.active .nav-label-sub{color:rgba(255,255,255,.5)}
.nav-item:hover .nav-label-sub{color:rgba(255,255,255,.5)}
.nav-badge{
  margin-left:auto;background:var(--green);color:#fff;
  font-size:10px;font-weight:700;padding:1px 6px;border-radius:20px;min-width:18px;text-align:center;
  box-shadow:0 2px 6px rgba(91,185,140,.4);
}
.nav-badge.blue{background:#4F7CAC}
.s-bottom{padding:12px 14px;border-top:1px solid rgba(255,255,255,.08)}
.provider-pill{
  display:flex;align-items:center;gap:8px;
  padding:8px 12px;background:rgba(255,255,255,.06);border-radius:var(--radius-sm);
  font-size:12px;color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.1);
}
.pdot{width:7px;height:7px;border-radius:50%;background:var(--green);flex-shrink:0;box-shadow:0 0 8px rgba(91,185,140,.7)}

/* ── Main ── */
#main{flex:1;overflow:hidden;display:flex;flex-direction:column;background:var(--bg)}
.page{display:none;height:100%;overflow-y:auto;padding:28px 32px;animation:fadeIn .22s ease}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.ph{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:24px;padding-bottom:18px;
  border-bottom:1px solid var(--border);
}
.ph-text h2{font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.5px;line-height:1.2}
.ph-text p{font-size:13px;color:var(--text2);margin-top:4px;font-weight:400}

/* ── Stats ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.stat{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:22px 20px 18px;position:relative;overflow:hidden;transition:var(--t);cursor:default;
}
.stat:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:var(--shadow-md)}
/* Decorative circle in background */
.stat::before{
  content:'';position:absolute;top:-20px;right:-20px;
  width:90px;height:90px;border-radius:50%;
  opacity:.055;pointer-events:none;
}
.stat.c-blue::before{background:var(--accent)}
.stat.c-purple::before{background:var(--purple)}
.stat.c-yellow::before{background:var(--yellow)}
.stat.c-green::before{background:var(--green)}
/* Top accent line */
.stat::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:3px 3px 0 0}
.stat.c-blue::after{background:linear-gradient(90deg,var(--blue),var(--accent))}
.stat.c-purple::after{background:linear-gradient(90deg,var(--purple),#6366f1)}
.stat.c-yellow::after{background:linear-gradient(90deg,var(--yellow),#f97316)}
.stat.c-green::after{background:linear-gradient(90deg,var(--green),#34d399)}
/* Icon bubble */
.stat-icon{
  font-size:17px;margin-bottom:14px;
  display:inline-flex;align-items:center;justify-content:center;
  width:42px;height:42px;border-radius:11px;
}
.stat.c-blue .stat-icon{background:var(--blue-d)}
.stat.c-purple .stat-icon{background:var(--purple-d)}
.stat.c-yellow .stat-icon{background:var(--yellow-d)}
.stat.c-green .stat-icon{background:var(--green-d)}
.stat-n{font-size:32px;font-weight:800;color:var(--text);line-height:1;letter-spacing:-.5px}
.stat-l{font-size:12px;color:var(--text2);margin-top:6px;font-weight:500}

/* ── Table ── */
.tbl-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
table{width:100%;border-collapse:collapse}
thead{background:var(--card2)}
th{padding:11px 16px;text-align:left;font-size:10.5px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.08em}
td{padding:11px 16px;font-size:13.5px;border-top:1px solid var(--border);color:var(--text)}
tbody tr{transition:background .12s}
tbody tr:hover td{background:var(--accent-light);cursor:pointer}
tbody tr:hover td:first-child{border-left:3px solid var(--accent)}
.sbadge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:600}
.s-Envoyée{background:rgba(107,114,128,.12);color:#6B7280}
.s-En-attente{background:var(--yellow-d);color:var(--yellow)}
.s-Entretien{background:var(--blue-d);color:var(--blue)}
.s-Acceptée{background:var(--green-d);color:var(--green)}
.s-Refusée{background:var(--red-d);color:var(--red)}

/* ── Buttons ── */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:8px 18px;border-radius:var(--radius-sm);
  font-size:13.5px;font-weight:600;cursor:pointer;border:none;transition:var(--t);
  font-family:'Inter',sans-serif;white-space:nowrap;letter-spacing:-.1px;
}
.btn-primary{
  background:linear-gradient(135deg,#3a6cc0,#2F5DA8);color:#fff;
  box-shadow:0 2px 8px rgba(47,93,168,.25),0 1px 2px rgba(47,93,168,.15);
}
.btn-primary:hover{
  background:linear-gradient(135deg,#4a7ed4,#3a6cc0);
  box-shadow:0 4px 16px rgba(47,93,168,.38),0 1px 3px rgba(47,93,168,.2);
  transform:translateY(-1px);
}
.btn-primary:active{transform:translateY(0);box-shadow:0 1px 4px rgba(47,93,168,.2)}
.btn-secondary{
  background:var(--card);color:var(--text);border:1px solid var(--border2);
  box-shadow:0 1px 2px rgba(30,58,95,.04);
}
.btn-secondary:hover{background:var(--card2);border-color:var(--accent);color:var(--accent)}
.btn-green{background:linear-gradient(135deg,#6acca0,#5BB98C);color:#fff;box-shadow:0 2px 8px rgba(91,185,140,.3)}
.btn-green:hover{background:linear-gradient(135deg,#5BB98C,#059669);box-shadow:0 4px 14px rgba(91,185,140,.4);transform:translateY(-1px)}
.btn-red{background:linear-gradient(135deg,#e85d53,#E0453A);color:#fff;box-shadow:0 2px 8px rgba(224,69,58,.25)}
.btn-red:hover{background:linear-gradient(135deg,#E0453A,#dc2626);box-shadow:0 4px 14px rgba(224,69,58,.35);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--text2);padding:6px 10px}
.btn-ghost:hover{background:var(--card);color:var(--text)}
.btn-sm{padding:5px 12px;font-size:12.5px}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none!important;box-shadow:none!important}

/* ── Inputs ── */
input,textarea,select{
  background:var(--card2);border:1.5px solid var(--border);border-radius:var(--radius-sm);
  color:var(--text);font-family:'Inter',sans-serif;font-size:13.5px;
  padding:9px 12px;transition:border-color .18s,box-shadow .18s,background .18s;outline:none;width:100%;
}
input:hover,textarea:hover,select:hover{border-color:var(--border2);background:var(--surface)}
input:focus,textarea:focus,select:focus{
  border-color:var(--accent);
  background:var(--surface);
  box-shadow:0 0 0 3.5px rgba(47,93,168,.1);
}
input::placeholder,textarea::placeholder{color:var(--text3)}
textarea{resize:vertical;min-height:80px}
label{font-size:11.5px;font-weight:700;color:var(--text2);display:block;margin-bottom:5px;letter-spacing:.03em;text-transform:uppercase}
.fg{margin-bottom:16px}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.row2 .fg{margin-bottom:0}

/* ── Card ── */
.card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:22px;box-shadow:var(--shadow);
}
.card-title{
  font-size:14px;font-weight:800;color:var(--text);margin-bottom:18px;
  display:flex;align-items:center;gap:8px;letter-spacing:-.2px;
}

/* ── Adapter ── */
#page-adapter .layout{display:grid;grid-template-columns:1fr 1fr;gap:16px;height:calc(100vh - 172px)}
.adapter-in{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:22px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;
  box-shadow:var(--shadow);
}
.adapter-out{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:20px;display:flex;flex-direction:column;gap:12px;position:relative;
  box-shadow:var(--shadow);
}
#cv-preview{width:100%;flex:1;border:none;border-radius:var(--radius-sm);background:#fff;min-height:0}
.gen-overlay{
  position:absolute;inset:0;background:rgba(7,9,15,.92);
  display:none;align-items:center;justify-content:center;
  flex-direction:column;gap:20px;border-radius:var(--radius);z-index:5;
  backdrop-filter:blur(4px);
}
.gen-overlay.show{display:flex}
.spinner{
  width:38px;height:38px;border:3px solid var(--border2);
  border-top-color:var(--accent);border-radius:50%;
  animation:spin .75s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── CV Generation Overlay ── */
.gen-photo-ring{
  position:relative;width:96px;height:96px;
}
.gen-photo-ring::before{
  content:'';position:absolute;inset:-5px;border-radius:50%;
  background:conic-gradient(var(--accent),var(--blue),var(--purple),var(--accent));
  animation:spin 2s linear infinite;
}
.gen-photo-ring::after{
  content:'';position:absolute;inset:-5px;border-radius:50%;
  background:conic-gradient(var(--accent),var(--blue),var(--purple),var(--accent));
  animation:spin 2s linear infinite;filter:blur(8px);opacity:.5;
}
.gen-photo-inner{
  position:relative;z-index:1;
  width:96px;height:96px;border-radius:50%;overflow:hidden;
  border:3px solid var(--bg);background:var(--card2);
  display:flex;align-items:center;justify-content:center;
  font-size:36px;
}
.gen-photo-inner img{width:100%;height:100%;object-fit:cover}
.gen-label{
  font-size:14px;font-weight:600;color:#fff;letter-spacing:-.2px;
  text-align:center;min-height:22px;
}
.gen-sublabel{
  font-size:11.5px;color:var(--text2);text-align:center;
}
.gen-dots{display:flex;gap:6px;align-items:center}
.gen-dots span{
  width:7px;height:7px;border-radius:50%;background:var(--accent);
  animation:dotBounce 1.2s ease-in-out infinite;
}
.gen-dots span:nth-child(2){animation-delay:.2s}
.gen-dots span:nth-child(3){animation-delay:.4s}
@keyframes dotBounce{
  0%,80%,100%{transform:translateY(0);opacity:.4}
  40%{transform:translateY(-6px);opacity:1}
}

/* ── Kanban ── */
#page-applications .ph{margin-bottom:16px}
.kanban{display:grid;grid-template-columns:repeat(5,1fr);gap:13px;height:calc(100vh - 178px)}
.kcol{display:flex;flex-direction:column;gap:10px;min-height:0}
.kcol-hd{
  padding:10px 13px;border-radius:var(--radius-sm);
  font-size:10.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  display:flex;align-items:center;gap:8px;flex-shrink:0;
}
.kcol-hd .cnt{
  margin-left:auto;font-size:11.5px;font-weight:700;
  padding:1px 8px;border-radius:20px;background:rgba(0,0,0,.06);
}
.col-Envoyée .kcol-hd{background:rgba(107,114,128,.09);color:#6B7280}
.col-En-attente .kcol-hd{background:var(--yellow-d);color:var(--yellow)}
.col-Entretien .kcol-hd{background:var(--blue-d);color:var(--blue)}
.col-Acceptée .kcol-hd{background:var(--green-d);color:var(--green)}
.col-Refusée .kcol-hd{background:var(--red-d);color:var(--red)}
.kcol-body{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:7px;padding-bottom:6px}
.kcard{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:12px 13px 12px 15px;cursor:pointer;transition:var(--t);
  position:relative;overflow:hidden;
}
/* Colored left border by column */
.kcard::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px;
  transition:width .18s;
}
.col-Envoyée .kcard::before{background:#9CA3AF}
.col-En-attente .kcard::before{background:var(--yellow)}
.col-Entretien .kcard::before{background:var(--blue)}
.col-Acceptée .kcard::before{background:var(--green)}
.col-Refusée .kcard::before{background:var(--red)}
.kcard:hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:var(--shadow-md)}
.kcard:hover::before{width:4px}
.kcard h5{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px;line-height:1.3}
.kcard-co{font-size:12px;color:var(--text2);font-weight:500}
.kcard-date{font-size:11px;color:var(--text3);margin-top:7px}
.kcard-int{font-size:11px;color:var(--blue);margin-top:3px;font-weight:600}
.kcard-note{font-size:11px;color:var(--text3);margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
.drop-zone{
  border:2px dashed var(--border2);border-radius:var(--radius-sm);
  padding:18px;text-align:center;color:var(--text3);font-size:12px;min-height:58px;
  transition:var(--t);
}
.drop-zone.over{border-color:var(--accent);background:var(--accent-light)}

/* ── Interviews ── */
#page-interviews .layout{display:grid;grid-template-columns:290px 1fr;gap:16px;height:calc(100vh - 172px)}
.al{overflow-y:auto;display:flex;flex-direction:column;gap:6px}
.al-item{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:13px 14px;cursor:pointer;transition:var(--t);
  position:relative;overflow:hidden;
}
.al-item::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:0;
  background:var(--accent);transition:width .18s;
}
.al-item:hover{border-color:var(--border2);box-shadow:var(--shadow)}
.al-item:hover::before{width:3px}
.al-item.active{border-color:var(--accent);background:var(--accent-light);box-shadow:0 0 0 1px var(--accent) inset}
.al-item.active::before{width:3px}
.al-item h5{font-size:13px;font-weight:700;color:var(--text);line-height:1.3}
.al-item p{font-size:12px;color:var(--text2);margin-top:2px;font-weight:500}
.al-item .prep-ok{
  font-size:10.5px;color:var(--green);margin-top:5px;font-weight:600;
  display:inline-flex;align-items:center;gap:3px;
}
.prep-panel{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:26px;overflow-y:auto;display:flex;flex-direction:column;gap:0;
  box-shadow:var(--shadow);
}
.prep-raw{font-size:13.5px;color:var(--text);line-height:1.9;white-space:pre-wrap;font-family:'Inter',sans-serif}

/* ── Settings ── */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.prov-toggle{display:flex;gap:9px;margin-bottom:4px}
.prov-btn{
  flex:1;padding:11px 14px;border-radius:var(--radius-sm);
  border:1.5px solid var(--border);background:var(--card2);
  color:var(--text2);cursor:pointer;text-align:center;
  font-size:13px;font-weight:600;transition:var(--t);font-family:'Inter',sans-serif;
}
.prov-btn:hover{border-color:var(--border2);background:var(--card)}
.prov-btn.active{
  border-color:var(--accent);background:var(--accent-light);color:var(--accent);
  box-shadow:0 0 0 3px rgba(47,93,168,.1);
}

/* ── Toast ── */
#toasts{position:fixed;bottom:24px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:9999}
.toast{
  padding:12px 16px;border-radius:12px;font-size:13px;font-weight:500;
  min-width:260px;max-width:340px;display:flex;align-items:center;gap:10px;
  animation:toastIn .3s cubic-bezier(.34,1.56,.64,1);
  box-shadow:0 4px 24px rgba(14,28,56,.12),0 1px 4px rgba(14,28,56,.08);
}
.toast::before{
  font-size:16px;flex-shrink:0;width:22px;text-align:center;
}
.toast.success{background:#f0faf5;color:#0a5c35;border:1px solid rgba(91,185,140,.4)}
.toast.success::before{content:'✅'}
.toast.error{background:#fff5f5;color:#991b1b;border:1px solid rgba(224,69,58,.35)}
.toast.error::before{content:'❌'}
.toast.info{background:#EBF1FB;color:var(--accent2);border:1px solid rgba(47,93,168,.3)}
.toast.info::before{content:'ℹ️'}
@keyframes toastIn{from{transform:translateX(110%) scale(.95);opacity:0}to{transform:none;opacity:1}}

/* ── Modal ── */
#modal-bg{
  position:fixed;inset:0;background:rgba(14,28,56,.6);
  display:none;align-items:center;justify-content:center;z-index:1000;
  backdrop-filter:blur(8px);
}
#modal-bg.open{display:flex}
.modal{
  background:var(--card);border:1px solid var(--border);border-radius:18px;
  padding:0;width:500px;max-width:93vw;max-height:90vh;overflow:hidden;
  display:flex;flex-direction:column;
  box-shadow:0 8px 40px rgba(14,28,56,.25),0 2px 8px rgba(14,28,56,.1);
  animation:mIn .22s cubic-bezier(.34,1.56,.64,1);
}
.modal-body-scroll{overflow-y:auto;padding:0 24px 24px;flex:1}
@keyframes mIn{from{transform:scale(.9) translateY(10px);opacity:0}to{transform:none;opacity:1}}
.modal-hd{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 24px 18px;
  border-bottom:1px solid var(--border);
  background:var(--card);
  position:sticky;top:0;z-index:2;flex-shrink:0;
}
.modal-hd h3{font-size:16px;font-weight:800;color:var(--text);letter-spacing:-.3px}
.modal-x{
  background:var(--card2);border:1px solid var(--border);color:var(--text2);
  font-size:15px;cursor:pointer;padding:5px 8px;line-height:1;border-radius:8px;
  transition:var(--t);
}
.modal-x:hover{background:var(--border);color:var(--text)}
.modal-ft{display:flex;gap:9px;justify-content:flex-end;padding:16px 24px;border-top:1px solid var(--border);flex-shrink:0;background:var(--card)}
hr.div{border:none;border-top:1px solid var(--border);margin:16px 0}

/* ── Utils ── */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:10px}
::-webkit-scrollbar-thumb:hover{background:var(--accent);opacity:.5}
.flex{display:flex}.gap-2{gap:8px}.gap-3{gap:12px}.items-c{align-items:center}
.justify-b{justify-content:space-between}.ml-a{margin-left:auto}
.tx-sm{font-size:12.5px}.tx-m{color:var(--text2)}.fw6{font-weight:600}
.mt1{margin-top:4px}.mt2{margin-top:8px}.mt3{margin-top:14px}
.empty{
  text-align:center;padding:50px 20px;color:var(--text3);
  display:flex;flex-direction:column;align-items:center;gap:4px;
}
.empty-i{
  font-size:42px;margin-bottom:12px;
  width:72px;height:72px;border-radius:20px;
  background:var(--card2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
}
.empty h4{font-size:15px;font-weight:700;color:var(--text2);margin-bottom:6px;margin-top:4px}
.empty p{font-size:13px;line-height:1.65;max-width:260px}
.hidden{display:none!important}
.chip{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:600}

/* ── Templates CV ── */
.tpl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}
.tpl-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;transition:var(--t);display:flex;flex-direction:column;
  box-shadow:var(--shadow);
}
.tpl-card:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:var(--shadow-md)}
.tpl-thumb{height:140px;background:var(--card2);overflow:hidden;position:relative;cursor:pointer}
.tpl-thumb iframe{width:200%;height:200%;transform:scale(.5);transform-origin:top left;pointer-events:none;border:none}
.tpl-thumb-overlay{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:rgba(30,58,95,.5);opacity:0;transition:var(--t);cursor:pointer;
  backdrop-filter:blur(2px);
}
.tpl-card:hover .tpl-thumb-overlay{opacity:1}
.tpl-info{padding:13px 14px;flex:1;display:flex;flex-direction:column;gap:8px}
.tpl-name{font-size:13px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tpl-meta{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:6px}
.tpl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.tpl-actions{display:flex;gap:6px;margin-top:auto}
.tpl-btn{
  flex:1;padding:7px 8px;border-radius:8px;border:1px solid var(--border);
  background:var(--card2);color:var(--text2);font-size:11px;font-weight:600;
  cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif;text-align:center;
}
.tpl-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}
.tpl-btn.danger:hover{border-color:var(--red);color:var(--red);background:var(--red-d)}
.tpl-btn.primary{background:linear-gradient(135deg,#3a6cc0,#2F5DA8);border-color:var(--accent);color:#fff}
.tpl-btn.primary:hover{background:linear-gradient(135deg,#4a7ed4,#3a6cc0)}
.tpl-empty-state{
  grid-column:1/-1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;padding:60px 20px;color:var(--text3);gap:14px;
}
/* ── Wizard Templates CV ── */
#tpl-gen-overlay{
  position:fixed;inset:0;background:rgba(14,28,56,.65);z-index:8000;
  display:none;align-items:center;justify-content:center;padding:20px;
  backdrop-filter:blur(12px) saturate(150%);
}
#tpl-gen-overlay.open{display:flex}
.wiz-card{
  background:var(--card);border:1px solid var(--border);border-radius:22px;
  width:100%;max-width:600px;max-height:90vh;display:flex;flex-direction:column;
  overflow:hidden;
  box-shadow:0 24px 80px rgba(14,28,56,.3),0 4px 20px rgba(14,28,56,.12);
  animation:mIn .24s cubic-bezier(.34,1.56,.64,1);
}
.wiz-head{padding:20px 24px 0;flex-shrink:0}
.wiz-prog-wrap{height:4px;background:var(--border);border-radius:99px;margin-bottom:16px;overflow:hidden}
.wiz-prog-bar{
  height:100%;border-radius:99px;transition:width .45s cubic-bezier(.4,0,.2,1);
  background:linear-gradient(90deg,var(--accent) 0%,#5B9FE8 50%,var(--green) 100%);
  box-shadow:0 0 8px rgba(47,93,168,.4);
}
.wiz-head-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.wiz-step-lbl{font-size:11px;font-weight:600;color:var(--text3);letter-spacing:.08em;text-transform:uppercase}
.wiz-body{flex:1;overflow-y:auto;padding:24px 24px 0}
/* Hook screen */
.wiz-hook{text-align:center;padding:20px 0 30px;display:flex;flex-direction:column;align-items:center;gap:16px}
.wiz-hook-icon{font-size:52px;line-height:1}
.wiz-hook-title{font-size:26px;font-weight:800;color:var(--text);line-height:1.2}
.wiz-hook-sub{font-size:15px;color:var(--text2);line-height:1.6;max-width:400px}
/* Questions */
.wiz-q-block{margin-bottom:24px}
.wiz-q-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:4px;line-height:1.3}
.wiz-q-sub{font-size:13px;color:var(--text3);margin-bottom:14px}
/* Option cards (objectif) */
.wiz-opts{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.wiz-opt{padding:13px 14px;border-radius:12px;border:1px solid var(--border);background:var(--card2);cursor:pointer;transition:var(--t);display:flex;align-items:center;gap:10px;font-family:'Inter',sans-serif}
.wiz-opt:hover{border-color:var(--border2)}
.wiz-opt.sel{border-color:var(--accent);background:var(--accent-light)}
.wiz-opt-icon{font-size:20px;flex-shrink:0}
.wiz-opt-label{font-size:13px;font-weight:600;color:var(--text)}
/* Chips */
.wiz-chips{display:flex;gap:8px;flex-wrap:wrap}
.wiz-chip{padding:7px 16px;border-radius:20px;border:1px solid var(--border2);background:var(--card2);color:var(--text2);font-size:13px;font-weight:600;cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif}
.wiz-chip:hover{border-color:var(--accent);color:var(--text)}
.wiz-chip.sel{border-color:var(--accent);background:var(--accent-light);color:var(--accent)}
.wiz-chip.disabled{opacity:.4;pointer-events:none}
/* Color swatches */
.wiz-colors{display:flex;gap:10px;flex-wrap:wrap}
.wiz-color{width:36px;height:36px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:var(--t);flex-shrink:0}
.wiz-color:hover{transform:scale(1.1)}
.wiz-color.sel{border-color:#fff;transform:scale(1.15);box-shadow:0 0 0 2px var(--accent)}
/* Text input */
.wiz-input{width:100%;background:var(--card2);border:1px solid var(--border2);color:var(--text);border-radius:10px;padding:10px 14px;font-size:14px;outline:none;font-family:'Inter',sans-serif;transition:var(--t)}
.wiz-input:focus{border-color:var(--accent)}
/* Generating screen */
.wiz-generating{text-align:center;padding:40px 20px;display:flex;flex-direction:column;align-items:center;gap:18px}
.wiz-gen-spin{width:48px;height:48px;border:3px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite}
/* Footer */
.wiz-foot{padding:18px 24px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);flex-shrink:0;gap:10px;margin-top:16px}
.wiz-back{background:none;border:1px solid var(--border);color:var(--text2);padding:9px 18px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif}
.wiz-back:hover{border-color:var(--border2);color:var(--text)}
.wiz-next{background:var(--accent);border:none;color:#fff;padding:9px 24px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif;margin-left:auto}
.wiz-next:hover{background:var(--accent2)}
.wiz-next:disabled{opacity:.4;cursor:default}

/* ── Custom Color Picker ── */
.wiz-cp-wrap{margin-top:4px}
/* Slots */
.wiz-cp-slots{display:flex;gap:8px;margin-bottom:14px}
.wiz-cp-slot{
  flex:1;height:50px;border-radius:10px;cursor:pointer;position:relative;
  border:3px solid transparent;transition:all .18s;
  display:flex;flex-direction:column;justify-content:flex-end;padding:5px 7px;
  box-shadow:0 2px 8px rgba(0,0,0,.3);
}
.wiz-cp-slot.active{border-color:#fff;transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,.5)}
.wiz-cp-slot-label{font-size:9px;font-weight:700;color:rgba(255,255,255,.8);text-transform:uppercase;letter-spacing:.08em;line-height:1}
.wiz-cp-slot-empty{font-size:16px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:.5}
/* SV Square */
.wiz-cp-sq-wrap{position:relative;width:100%;padding-bottom:55%;border-radius:10px;overflow:hidden;margin-bottom:10px;cursor:crosshair;touch-action:none}
.wiz-cp-sq-hue{position:absolute;inset:0;border-radius:10px}
.wiz-cp-sq-white{position:absolute;inset:0;background:linear-gradient(to right,#fff,transparent);border-radius:10px}
.wiz-cp-sq-black{position:absolute;inset:0;background:linear-gradient(to bottom,transparent,#000);border-radius:10px}
.wiz-cp-sq-cursor{position:absolute;width:16px;height:16px;border-radius:50%;border:2.5px solid #fff;transform:translate(-50%,-50%);pointer-events:none;box-shadow:0 0 0 1.5px rgba(0,0,0,.4),0 2px 6px rgba(0,0,0,.5)}
/* Hue Slider */
.wiz-cp-hue-wrap{position:relative;height:14px;border-radius:99px;margin-bottom:10px;cursor:pointer;touch-action:none;
  background:linear-gradient(to right,#f00 0%,#ff0 17%,#0f0 33%,#0ff 50%,#00f 67%,#f0f 83%,#f00 100%)}
.wiz-cp-hue-cursor{position:absolute;top:50%;width:20px;height:20px;border-radius:50%;border:2.5px solid #fff;transform:translate(-50%,-50%);pointer-events:none;box-shadow:0 0 0 1.5px rgba(0,0,0,.35),0 2px 6px rgba(0,0,0,.5)}
/* Hex row */
.wiz-cp-hex-row{display:flex;gap:8px;align-items:center}
.wiz-cp-hex{flex:1;background:var(--card2);border:1px solid var(--border2);color:var(--text);border-radius:8px;padding:7px 10px;font-size:13px;font-family:'Inter',sans-serif;outline:none;transition:border-color .15s;letter-spacing:.05em}
.wiz-cp-hex:focus{border-color:var(--accent)}
.wiz-cp-preview{width:36px;height:36px;border-radius:8px;flex-shrink:0;border:2px solid var(--border2);box-shadow:0 2px 8px rgba(0,0,0,.3)}

/* ══════════════════════════════════════════════════════════════════
   RESPONSIVE — Mobile-first
══════════════════════════════════════════════════════════════════ */

/* ── Sidebar backdrop ── */
#sidebar-backdrop{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);
  z-index:199;backdrop-filter:blur(3px);
}
#sidebar-backdrop.show{display:block}

/* Hamburger — masqué par défaut, visible uniquement sur mobile via media query */
#menu-toggle{display:none}

/* ── Bottom navigation bar (mobile) ── */
#bottom-nav{
  display:none;
  position:fixed;bottom:0;left:0;right:0;
  height:62px;
  background:rgba(255,255,255,.88);
  backdrop-filter:blur(20px) saturate(180%);
  -webkit-backdrop-filter:blur(20px) saturate(180%);
  border-top:1px solid rgba(226,234,244,.8);
  box-shadow:0 -4px 20px rgba(30,58,95,.06);
  z-index:500;
  align-items:stretch;
  padding:0 4px;
  padding-bottom:env(safe-area-inset-bottom);
}
.bn-btn{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;background:none;border:none;color:var(--text3);cursor:pointer;
  font-size:10px;font-weight:600;font-family:'Inter',sans-serif;
  padding:8px 4px;border-radius:10px;transition:var(--t);position:relative;
  -webkit-tap-highlight-color:transparent;
}
.bn-btn:active{background:var(--card2);transform:scale(.95)}
.bn-btn.active{color:var(--accent)}
/* Active dot indicator above icon */
.bn-btn.active::before{
  content:'';position:absolute;top:5px;left:50%;transform:translateX(-50%);
  width:18px;height:3px;border-radius:99px;
  background:var(--accent);opacity:.7;
}
.bn-btn .bn-icon{font-size:20px;line-height:1}
.bn-btn .bn-label{font-size:10px;font-weight:600;white-space:nowrap}
/* FAB center button */
.bn-fab{
  flex:1;display:flex;align-items:center;justify-content:center;
  background:none;border:none;cursor:pointer;padding:6px 4px;
  -webkit-tap-highlight-color:transparent;
}
.bn-fab-inner{
  width:48px;height:48px;background:var(--accent);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:24px;color:#fff;font-weight:300;
  box-shadow:0 4px 18px rgba(47,93,168,.45);
  transition:var(--t);line-height:1;
  margin-top:-18px;/* rises above nav bar */
}
.bn-fab:active .bn-fab-inner{transform:scale(.92)}

/* Badge on bottom nav */
.bn-badge{
  position:absolute;top:6px;right:calc(50% - 18px);
  background:var(--accent);color:#fff;font-size:9px;font-weight:800;
  padding:1px 4px;border-radius:20px;min-width:14px;text-align:center;
  display:none;
}
.bn-badge.show{display:block}

/* Mobile card list (apps + dash) */
.m-card-list{display:flex;flex-direction:column;gap:8px}
.m-app-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:13px 14px;
  cursor:pointer;transition:var(--t);
  display:flex;align-items:center;gap:12px;
}
.m-app-card:active{background:var(--card2)}
.m-app-card-body{flex:1;min-width:0}
.m-app-card-co{font-size:14px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-app-card-role{font-size:12px;color:var(--text2);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-app-card-foot{display:flex;align-items:center;gap:8px;margin-top:6px}
.m-app-card-date{font-size:11px;color:var(--text3)}
.m-app-card-arrow{color:var(--text3);font-size:16px;flex-shrink:0}

/* Mobile kanban tabs */
.mob-status-tabs{
  display:flex;gap:0;overflow-x:auto;-webkit-overflow-scrolling:touch;
  scrollbar-width:none;border-radius:var(--radius-sm);
  background:var(--card);border:1px solid var(--border);
  margin-bottom:14px;padding:4px;gap:3px;
}
.mob-status-tabs::-webkit-scrollbar{display:none}
.mob-stab{
  flex-shrink:0;padding:7px 13px;border-radius:7px;
  font-size:12px;font-weight:600;cursor:pointer;
  background:none;border:none;color:var(--text2);
  font-family:'Inter',sans-serif;transition:var(--t);white-space:nowrap;
  -webkit-tap-highlight-color:transparent;
}
.mob-stab.active{background:var(--accent);color:#fff}

/* ── Tablet (≤ 1100px) ── */
@media(max-width:1100px){
  #sidebar{width:186px;min-width:186px}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .kanban{grid-template-columns:repeat(3,1fr)}
}

/* ── Mobile (≤ 768px) ── */
@media(max-width:768px){
  /* ═══ RÈGLE FONDAMENTALE : zéro scroll horizontal ═══ */
  html,body{
    overflow-x:hidden!important;
    overflow-y:auto;
    width:100%;
    max-width:100vw;
  }
  *{box-sizing:border-box}
  #app{flex-direction:column;overflow-x:hidden;max-width:100vw;width:100%}
  #main{width:100%;max-width:100vw;overflow-x:hidden}
  .page{
    padding:18px 14px calc(72px + env(safe-area-inset-bottom));
    height:auto;min-height:100vh;
    overflow-x:hidden;overflow-y:auto;
    max-width:100vw;
  }

  /* Hide desktop sidebar, show bottom nav */
  #menu-toggle{display:none!important}
  #bottom-nav{display:flex}
  #sidebar{
    position:fixed;top:0;left:0;height:100vh;z-index:200;
    width:80vw;max-width:280px;min-width:0;
    transform:translateX(-100%);transition:transform .28s cubic-bezier(.4,0,.2,1);
    overflow-y:auto;overflow-x:hidden;
  }
  #sidebar.open{transform:translateX(0);box-shadow:4px 0 32px rgba(0,0,0,.6)}

  /* Toasts : ne dépassent pas */
  #toasts{right:12px;bottom:80px;left:12px;max-width:calc(100vw - 24px)}
  .toast{min-width:0;width:100%}

  /* Page header */
  .ph{flex-direction:column;align-items:flex-start;gap:10px;margin-bottom:16px}
  .ph .flex{width:100%}
  .ph .btn{flex:1;justify-content:center;min-height:40px}

  /* Stats 2 colonnes */
  .stats-grid{grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
  .stat{padding:14px 12px}
  .stat-n{font-size:22px}
  .stat-l{font-size:11px}

  /* Dashboard : cartes mobile */
  .tbl-wrap{display:none}
  #dash-cards{display:flex!important}

  /* Adapter */
  #page-adapter .layout{grid-template-columns:1fr;height:auto;gap:12px}
  .adapter-in,.adapter-out{min-height:280px}
  #cv-preview{min-height:360px}
  .adapter-header-btns{display:none!important}
  #adapter-mobile-actions{display:flex!important}

  /* Kanban → version mobile */
  .kanban{display:none!important}
  #kanban-mobile{display:block!important}
  .mob-status-tabs{
    overflow-x:auto;-webkit-overflow-scrolling:touch;
    scrollbar-width:none;
  }
  .mob-status-tabs::-webkit-scrollbar{display:none}

  /* Interviews */
  #page-interviews .layout{grid-template-columns:1fr;height:auto;gap:12px}
  .al{max-height:280px}

  /* Settings */
  .settings-grid{grid-template-columns:1fr}

  /* Calendar nav */
  .cal-nav{flex-wrap:wrap;gap:6px;padding:8px 10px}
  .cal-title-wrap{order:-1;width:100%;text-align:center}

  /* Calendar 7j : scroll interne contenu dans une box */
  #cal-grid{max-width:100%;overflow:hidden}
  .cal-7{
    display:flex;gap:6px;
    overflow-x:auto;-webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom:6px;
    /* Contenu la liste — ne déborde pas de la page */
    max-width:100%;
  }
  .cal-7::-webkit-scrollbar{display:none}
  .cal-day-col{min-width:100px;flex-shrink:0}
  .cal-day-num{font-size:16px}

  /* Calendar 30j */
  .cal-30{gap:2px;max-width:100%}
  .cal-30-cell{padding:4px;min-height:52px}
  .cal-30-hdr{font-size:9px;padding:4px 0}
  .cal-30-num{font-size:11px}

  /* Planning filters : scroll interne */
  .planning-filters{
    flex-wrap:nowrap;
    overflow-x:auto;-webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom:4px;
    max-width:100%;
  }
  .planning-filters::-webkit-scrollbar{display:none}
  .plan-pill{flex-shrink:0}
  .plan-search{display:none}

  /* Form grid */
  .row2{grid-template-columns:1fr}
  .row2 .fg{margin-bottom:14px}

  /* Modal → bottom sheet */
  #modal-bg{align-items:flex-end}
  .modal{
    width:100%;max-width:100%;border-radius:22px 22px 0 0;
    max-height:92vh;padding:0;
    animation:slideUp .3s cubic-bezier(.4,0,.2,1);
  }
  @keyframes slideUp{from{transform:translateY(100%);opacity:.7}to{transform:none;opacity:1}}
  .modal-hd{
    border-radius:22px 22px 0 0;
    padding:12px 20px 16px;
  }
  .modal-hd::before{
    content:'';display:block;width:36px;height:4px;
    background:var(--border2);border-radius:4px;
    margin:0 auto 14px;
  }
  .modal-body-scroll{padding:0 20px 20px}
  .modal-ft{padding:14px 20px calc(16px + env(safe-area-inset-bottom))}

  /* Wizard → bottom sheet */
  #tpl-gen-overlay{align-items:flex-end;padding:0}
  .wiz-card{
    border-radius:20px 20px 0 0;max-width:100%;width:100%;
    max-height:92vh;
  }
  .wiz-opts{grid-template-columns:1fr}
  .wiz-head{padding:16px 18px 0}

  /* Auth */
  #auth-overlay{flex-direction:column}
  .auth-left{display:none}
  .auth-right{width:100%;flex:1;padding:32px 20px;box-shadow:none}
  .auth-box{max-width:100%}

  /* Template grid */
  .tpl-grid{grid-template-columns:1fr 1fr;gap:10px}
  .tpl-thumb{height:110px}

  /* Inputs et formulaires : jamais plus larges que l'écran */
  input,textarea,select{max-width:100%}
  .wiz-cp-wrap{max-width:100%}
}

/* ── Small mobile (≤ 480px) ── */
@media(max-width:480px){
  .stats-grid{grid-template-columns:1fr 1fr}
  .tpl-grid{grid-template-columns:1fr}
  .page{padding-left:12px;padding-right:12px}
  .cal-day-col{min-width:88px}
}

/* ══════════════════════════════════════════════════════════
   GLOBAL PREMIUM POLISH
══════════════════════════════════════════════════════════ */

/* Focus-visible outline for accessibility */
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

/* Smooth page background */
#main{
  background:
    radial-gradient(ellipse at 80% 0%, rgba(47,93,168,.04) 0%, transparent 60%),
    radial-gradient(ellipse at 20% 100%, rgba(91,185,140,.03) 0%, transparent 60%),
    var(--bg);
}

/* Tag/chip polish */
.sbadge{
  font-weight:700;letter-spacing:.01em;
  box-shadow:0 1px 2px rgba(0,0,0,.04);
}

/* Better section separators */
.s-section-label{
  font-size:10px;font-weight:700;color:rgba(255,255,255,.28);
  letter-spacing:.1em;text-transform:uppercase;
  padding:12px 12px 4px;
}

/* Spinner refined */
.spinner{
  width:36px;height:36px;border-width:2.5px;
  border-top-color:var(--accent);
}

/* Admin table polish */
.admin-table th{
  background:var(--card2);
  font-size:10.5px;font-weight:700;color:var(--text3);
  text-transform:uppercase;letter-spacing:.08em;
}

/* Role badges */
.rb-admin{background:var(--red-d);color:var(--red);font-weight:700;border:1px solid rgba(224,69,58,.2)}
.rb-pro{background:var(--purple-d);color:var(--purple);font-weight:700;border:1px solid rgba(122,143,191,.2)}
.rb-membre{background:var(--card2);color:var(--text2);font-weight:700;border:1px solid var(--border)}

/* Calendar day header refinement */
.cal-day-hdr{
  background:linear-gradient(to bottom,var(--card2),var(--card));
}
.cal-day-col.cal-today{
  border-color:var(--accent);
  box-shadow:0 0 0 1px var(--accent) inset;
}

/* Wiz option card polish */
.wiz-opt{
  background:var(--card2);transition:var(--t);
}
.wiz-opt:hover{border-color:var(--accent);background:var(--accent-light);transform:translateY(-1px)}
.wiz-opt.sel{
  border-color:var(--accent);background:var(--accent-light);
  box-shadow:0 0 0 3px rgba(47,93,168,.1);
}
.wiz-opt-label{font-size:13px;font-weight:600;color:var(--text)}

/* CP slot polish */
.wiz-cp-slot:not(.active):hover{transform:scale(1.04);box-shadow:0 4px 12px rgba(0,0,0,.2)}

/* Wiz back/next buttons */
.wiz-back{
  background:var(--card2);border:1.5px solid var(--border);color:var(--text2);
  padding:9px 18px;border-radius:10px;font-size:13px;font-weight:600;
  cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif;
}
.wiz-back:hover{border-color:var(--border2);color:var(--text);background:var(--card)}
.wiz-next{
  background:linear-gradient(135deg,#3a6cc0,#2F5DA8);border:none;color:#fff;
  padding:9px 24px;border-radius:10px;font-size:14px;font-weight:700;
  cursor:pointer;transition:var(--t);font-family:'Inter',sans-serif;margin-left:auto;
  box-shadow:0 2px 10px rgba(47,93,168,.3);
}
.wiz-next:hover{
  background:linear-gradient(135deg,#4a7ed4,#3a6cc0);
  box-shadow:0 4px 18px rgba(47,93,168,.4);transform:translateY(-1px);
}
.wiz-next:disabled{opacity:.4;cursor:default;transform:none;box-shadow:none}

/* Selection states polish */
.wiz-chip:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light)}

/* Provider toggle active state */
.prov-btn.active::before{
  content:'✓ ';font-size:11px;
}

/* Page search placeholder */
#job-detail .empty{justify-content:center;height:100%}

/* Wiz generating spinner */
.wiz-gen-spin{
  width:52px;height:52px;
  border:3px solid var(--border);
  border-top-color:var(--accent);
  border-right-color:var(--blue);
  border-radius:50%;animation:spin .7s linear infinite;
}
</style>
</head>
<body>
<!-- Hamburger + backdrop (mobile) -->
<button id="menu-toggle" onclick="toggleSidebar()" aria-label="Menu">☰</button>
<div id="sidebar-backdrop" onclick="closeSidebar()"></div>

<div id="app">

<!-- ════ SIDEBAR ════ -->
<aside id="sidebar">
  <div class="s-logo">
    <div class="s-logo-mark">
      <div class="s-logo-icon">
        <svg viewBox="0 0 34 34" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
          <path d="M5 12Q5 9 8 9H26Q29 9 29 12V22Q29 25 26 25H19.5L17 29L14.5 25H8Q5 25 5 22Z" fill="rgba(255,255,255,.95)"/>
          <path d="M13 9V8Q13 7 14.5 7H19.5Q21 7 21 8V9" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round"/>
          <circle cx="17" cy="17" r="5.5" fill="#5BB98C"/>
          <circle cx="17" cy="17" r="3.2" fill="rgba(255,255,255,.95)"/>
          <circle cx="17" cy="17" r="1.3" fill="#5BB98C"/>
        </svg>
      </div>
      <h1>JobFinder</h1>
    </div>
    <p>Le copilote de ta recherche d'emploi</p>
  </div>
  <nav class="s-nav">
    <div class="nav-item active" data-page="dashboard">
      <span class="nav-icon">🏠</span>
      <span class="nav-label"><span class="nav-label-main">Tableau de bord</span><span class="nav-label-sub">Vue d'ensemble</span></span>
    </div>
    <div class="nav-item" data-page="adapter">
      <span class="nav-icon">✨</span>
      <span class="nav-label"><span class="nav-label-main">Adapter mon CV</span><span class="nav-label-sub">Personnaliser par offre</span></span>
    </div>
    <div class="nav-item" data-page="applications">
      <span class="nav-icon">📋</span>
      <span class="nav-label"><span class="nav-label-main">Candidatures</span><span class="nav-label-sub">Kanban & suivi</span></span>
      <span class="nav-badge" id="badge-apps">0</span>
    </div>
    <div class="nav-item" data-page="interviews">
      <span class="nav-icon">🎤</span>
      <span class="nav-label"><span class="nav-label-main">Entretiens</span><span class="nav-label-sub">Préparer ses réponses</span></span>
      <span class="nav-badge blue hidden" id="badge-int">0</span>
    </div>
    <div class="nav-item" data-page="planning">
      <span class="nav-icon">📅</span>
      <span class="nav-label"><span class="nav-label-main">Planning</span><span class="nav-label-sub">Calendrier d'entretiens</span></span>
    </div>
    <div class="nav-item" data-page="templates">
      <span class="nav-icon">🎨</span>
      <span class="nav-label"><span class="nav-label-main">Templates CV</span><span class="nav-label-sub">Créer & gérer ses modèles</span></span>
    </div>
    <div class="nav-item" data-page="settings">
      <span class="nav-icon">⚙️</span>
      <span class="nav-label"><span class="nav-label-main">Paramètres</span><span class="nav-label-sub">Profil, résumé, documents</span></span>
    </div>
    <div class="nav-item" data-page="admin" id="nav-admin" style="display:none">
      <span class="nav-icon">🛡️</span>
      <span class="nav-label"><span class="nav-label-main">Admin</span><span class="nav-label-sub">Gestion utilisateurs</span></span>
    </div>
  </nav>
  <div class="s-bottom">
    <div id="user-pill" style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:rgba(255,255,255,.07);border-radius:var(--radius-sm);border:1px solid rgba(255,255,255,.12);cursor:pointer" onclick="logout()">
      <span id="user-avatar" style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--accent));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0">?</span>
      <div style="flex:1;min-width:0">
        <div id="user-name" style="font-size:12px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">—</div>
        <div id="user-role-badge" style="font-size:10px;color:rgba(255,255,255,.45)">membre</div>
      </div>
      <span style="font-size:11px;color:rgba(255,255,255,.35)" title="Déconnexion">⏏</span>
    </div>
  </div>
</aside>

<!-- ════ BOTTOM NAV (mobile) ════ -->
<nav id="bottom-nav">
  <button class="bn-btn active" data-page="dashboard" onclick="nav('dashboard')">
    <span class="bn-icon">🏠</span>
    <span class="bn-label">Accueil</span>
  </button>
  <button class="bn-fab" onclick="openModal(null)" title="Nouvelle candidature">
    <div class="bn-fab-inner">+</div>
  </button>
  <button class="bn-btn" data-page="applications" onclick="nav('applications')">
    <span class="bn-icon">📋</span>
    <span class="bn-badge" id="bn-badge-apps">0</span>
    <span class="bn-label">Candidatures</span>
  </button>
  <button class="bn-btn" onclick="toggleSidebar()">
    <span class="bn-icon">☰</span>
    <span class="bn-label">Plus</span>
  </button>
</nav>

<!-- ════ MAIN ════ -->
<main id="main">

<!-- Dashboard -->
<div id="page-dashboard" class="page active">
  <div class="ph">
    <div class="ph-text"><h2>Tableau de bord</h2><p>Vue d'ensemble de votre recherche d'emploi</p></div>
    <div class="flex gap-2">
      <button class="btn btn-primary btn-sm" onclick="openModal(null)">+ Candidature</button>
    </div>
  </div>
  <div class="stats-grid">
    <div class="stat c-blue" onclick="nav('applications')" style="cursor:pointer" title="Voir toutes les candidatures"><div class="stat-icon">📤</div><div class="stat-n" id="st-total">0</div><div class="stat-l">Candidatures</div></div>
    <div class="stat c-purple" onclick="nav('interviews')" style="cursor:pointer" title="Préparer mes entretiens"><div class="stat-icon">🎤</div><div class="stat-n" id="st-int">0</div><div class="stat-l">Entretiens</div></div>
    <div class="stat c-yellow"><div class="stat-icon">⏳</div><div class="stat-n" id="st-pend">0</div><div class="stat-l">En attente</div></div>
    <div class="stat c-green"><div class="stat-icon">✅</div><div class="stat-n" id="st-acc">0</div><div class="stat-l">Acceptées</div></div>
  </div>

  <!-- Bannière profil incomplet -->
  <div id="profile-banner" style="display:none;margin-bottom:18px;padding:12px 16px;background:linear-gradient(135deg,rgba(47,93,168,.07),rgba(47,93,168,.04));border:1px solid rgba(47,93,168,.2);border-radius:12px;display:none;align-items:center;gap:12px">
    <span style="font-size:22px;flex-shrink:0">💡</span>
    <div style="flex:1;min-width:0">
      <div style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px">Complétez votre profil pour de meilleurs CV</div>
      <div style="font-size:12px;color:var(--text2)" id="profile-banner-msg">Ajoutez votre résumé et vos documents dans Paramètres.</div>
    </div>
    <button class="btn btn-secondary btn-sm" onclick="nav('settings')" style="flex-shrink:0">→ Compléter</button>
    <button onclick="document.getElementById('profile-banner').style.display='none'" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;padding:0;flex-shrink:0">✕</button>
  </div>

  <div class="tbl-wrap">
    <table>
      <thead><tr><th>Date</th><th>Entreprise</th><th>Poste</th><th>Statut</th><th>Entretien</th><th></th></tr></thead>
      <tbody id="dash-tbody"></tbody>
    </table>
  </div>
  <!-- Mobile card list (shown only on mobile via CSS) -->
  <div id="dash-cards" class="m-card-list" style="display:none"></div>
</div>

<!-- Adapter CV -->
<div id="page-adapter" class="page">
  <div class="ph">
    <div class="ph-text"><h2>✨ Adapter mon CV</h2><p>Votre CV adapté à chaque offre pour maximiser vos chances</p></div>
    <div class="flex gap-2">
      <button class="btn btn-secondary" onclick="previewCV()">👁️ Plein écran</button>
      <button class="btn btn-secondary" id="pdfbtn" onclick="downloadPDF()">⬇️ Télécharger PDF</button>
      <button class="btn btn-primary" id="genbtn" onclick="generateCV()">✨ Générer mon CV</button>
    </div>
  </div>
  <div class="layout">
    <div class="adapter-in">

      <!-- Import depuis une candidature -->
      <div class="card-title">📂 Importer depuis une candidature</div>
      <div class="flex gap-2 items-c" style="margin-bottom:14px">
        <select id="a-from-app" style="flex:1;background:var(--card2);border:1px solid var(--border2);color:var(--text);border-radius:10px;padding:9px 12px;font-size:13px;outline:none;font-family:'Inter',sans-serif;cursor:pointer" onchange="importFromApp(this.value)">
          <option value="">— Choisir une candidature existante —</option>
        </select>
      </div>

      <!-- URL fetch -->
      <div class="card-title">🔗 URL de l'annonce</div>
      <div class="flex gap-2 items-c" style="margin-bottom:14px">
        <input id="a-url" placeholder="https://fr.indeed.com/..." style="flex:1">
        <button class="btn btn-secondary btn-sm" id="fetchbtn" onclick="fetchURL()">⬇️ Récupérer</button>
      </div>
      <div id="fetch-status" class="tx-sm tx-m" style="margin-bottom:10px"></div>

      <div class="card-title">📋 Informations du poste</div>
      <div class="row2">
        <div class="fg"><label>Entreprise</label><input id="a-co" placeholder="Ex: Google, LVMH..."></div>
        <div class="fg"><label>Poste</label><input id="a-role" placeholder="Ex: Développeur Full Stack"></div>
      </div>
      <div class="fg">
        <label>Description de l'offre</label>
        <textarea id="a-desc" rows="8" placeholder="Collez ici le texte complet de l'offre (Indeed, LinkedIn, etc.) ou récupérez via l'URL..."></textarea>
      </div>

      <!-- Template mode toggle -->
      <div class="fg" style="margin-bottom:10px">
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
          <input type="checkbox" id="use-template" style="accent-color:var(--accent);width:16px;height:16px" checked>
          <span>Utiliser le template <strong>cv_vibe_modern</strong> (recommandé)</span>
        </label>
        <div class="tx-sm tx-m mt1" id="template-note">Le template cv_vibe_modern sera rempli automatiquement avec vos infos adaptées au poste.</div>
      </div>
      <div class="fg" id="cv-base-row" style="display:none">
        <label>CV de base (HTML) — si template désactivé</label>
        <div class="flex gap-2 items-c">
          <input id="a-cv-name" placeholder="Aucun CV sélectionné" readonly style="flex:1">
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('cv-file-inp').click()">📂 Choisir</button>
          <input type="file" id="cv-file-inp" accept=".html,.htm" style="display:none" onchange="loadCVFile(event)">
        </div>
      </div>

      <div id="doc-reminder" class="tx-sm" style="color:var(--yellow);margin-bottom:10px;display:none">⚠️ Aucune documentation chargée — ajoutez vos anciens CV dans <a href="#" onclick="nav('settings');return false" style="color:var(--accent)">Paramètres</a></div>
      <div id="gen-status" class="tx-sm tx-m"></div>
      <button class="btn btn-green" onclick="saveAndApply()" id="savebtn" style="display:none">💾 Sauvegarder &amp; Enregistrer candidature</button>
    </div>
    <div class="adapter-out">
      <div class="flex items-c justify-b">
        <span class="card-title" style="margin-bottom:0">👁️ Aperçu du CV adapté</span>
      </div>
      <iframe id="cv-preview" srcdoc="<body style='font-family:system-ui;color:#6B7280;display:flex;height:100%;align-items:center;justify-content:center;background:#F4F7FD;padding:24px;box-sizing:border-box'><div style='text-align:center;max-width:300px'><div style='font-size:40px;margin-bottom:14px'>✨</div><div style='font-size:15px;font-weight:700;color:#374151;margin-bottom:10px'>Comment ça marche</div><ol style='text-align:left;font-size:12px;line-height:1.8;color:#6B7280;padding-left:18px'><li>Choisissez une <b>candidature</b> ou collez l&apos;URL d&apos;une offre</li><li>Renseignez l&apos;entreprise et le poste</li><li>Cliquez sur <b>✨ Générer mon CV</b></li></ol><div style='font-size:11px;color:#9CA3AF;margin-top:12px'>Votre CV adapté apparaîtra ici</div></div></body>"></iframe>
      <div class="gen-overlay" id="gen-overlay">
        <div class="gen-photo-ring">
          <div class="gen-photo-inner" id="gen-photo-inner">🤖</div>
        </div>
        <div class="gen-label" id="gen-label">Analyse de l'offre...</div>
        <div class="gen-dots"><span></span><span></span><span></span></div>
        <div class="gen-sublabel">Optimisation en cours...</div>
      </div>
    </div>
  </div>
</div>

<!-- Candidatures Kanban -->
<div id="page-applications" class="page">
  <div class="ph">
    <div class="ph-text"><h2>📋 Mes candidatures</h2><p>Glissez les cartes d'une colonne à l'autre pour changer le statut</p></div>
    <button class="btn btn-primary btn-sm" onclick="openModal(null)">+ Ajouter</button>
  </div>
  <div class="kanban" id="kanban"></div>
  <!-- Vue mobile : tabs + liste -->
  <div id="kanban-mobile" style="display:none">
    <div class="mob-status-tabs" id="mob-status-tabs"></div>
    <div class="m-card-list" id="mob-kanban-list"></div>
  </div>
</div>

<!-- Entretiens -->
<div id="page-interviews" class="page">
  <div class="ph">
    <div class="ph-text"><h2>🎤 Préparer mes entretiens</h2><p>Fiches de questions/réponses générées pour chaque candidature</p></div>
  </div>
  <div class="layout">
    <div>
      <div class="tx-sm fw6 tx-m" style="margin-bottom:10px;letter-spacing:.06em;text-transform:uppercase">Candidatures</div>
      <div class="al" id="al"></div>
    </div>
    <div class="prep-panel" id="prep-panel">
      <div class="empty" style="margin:auto">
        <div class="empty-i">🎤</div>
        <h4>Sélectionnez une candidature</h4>
        <p>Choisissez une candidature pour générer ou consulter votre fiche d'entretien</p>
      </div>
    </div>
  </div>
</div>

<!-- Settings -->
<div id="page-settings" class="page">
  <div class="ph">
    <div class="ph-text"><h2>⚙️ Paramètres</h2><p>Complétez votre profil pour des CV plus personnalisés</p></div>
    <button class="btn btn-green" onclick="saveSettings()">💾 Sauvegarder</button>
  </div>
  <div class="settings-grid">
    <div class="card">
      <div class="card-title">📄 CV de base</div>
      <div class="fg">
        <label>Importer votre CV (.html)</label>
        <div class="flex gap-2 items-c">
          <input id="s-cv-name" placeholder="Aucun CV importé" readonly style="flex:1">
          <button class="btn btn-secondary btn-sm" onclick="document.getElementById('s-cv-inp').click()">📂 Choisir</button>
          <input type="file" id="s-cv-inp" accept=".html,.htm" style="display:none" onchange="importCV(event)">
        </div>
      </div>
      <div id="s-cv-status" class="tx-sm mt2" style="color:var(--green)"></div>
    </div>
    <div class="card" style="grid-column:1/-1">
      <div class="card-title">✍️ Mon résumé personnel</div>
      <div class="tx-sm tx-m" style="margin-bottom:12px;line-height:1.6">
        Décrivez vos expériences, réalisations, points forts, soft skills — tout ce que vous souhaitez mettre en avant. Plus vous êtes précis, plus le CV sera personnalisé. <strong style="color:var(--accent)">Ce texte sera utilisé en priorité.</strong>
      </div>
      <textarea id="s-summary" rows="8" placeholder="Ex: J'ai 4 ans d'expérience en développement commercial B2B. Chez TOPA j'ai augmenté le CA de 30% en 2 ans en restructurant la force de vente. Je suis à l'aise en négociation complexe, j'ai managé une équipe de 5 personnes, et j'ai mis en place un CRM Salesforce from scratch. Mon point fort c'est l'approche terrain combinée à une vraie compréhension des enjeux business..." style="width:100%;background:var(--card2);border:1px solid var(--border2);color:var(--text);border-radius:10px;padding:12px;font-size:13px;line-height:1.7;resize:vertical;font-family:inherit"></textarea>
      <div style="display:flex;justify-content:flex-end;margin-top:10px">
        <button class="btn btn-green btn-sm" onclick="saveSummary()">💾 Sauvegarder le résumé</button>
      </div>
      <div id="s-summary-status" class="tx-sm mt1" style="color:var(--green);text-align:right"></div>
    </div>
    <div class="card">
      <div class="card-title">📎 Ma documentation</div>
      <div class="tx-sm tx-m" style="margin-bottom:12px;line-height:1.6">Importez vos anciens CV, lettres de motivation, profils LinkedIn (PDF ou HTML) — ils serviront de base pour rédiger votre CV et préparer vos entretiens <strong style="color:var(--text)">sans rien inventer</strong>.</div>
      <div class="flex gap-2 items-c" style="margin-bottom:10px">
        <input id="s-doc-names" placeholder="Aucun document importé" readonly style="flex:1;font-size:12px">
        <button class="btn btn-secondary btn-sm" onclick="document.getElementById('s-doc-inp').click()">📂 Ajouter</button>
        <input type="file" id="s-doc-inp" accept=".html,.htm,.txt,.pdf" multiple style="display:none" onchange="loadSettingsDocs(event)">
        <button class="btn btn-red btn-sm" onclick="clearSettingsDocs()">✕</button>
      </div>
      <div id="s-doc-status" class="tx-sm" style="color:var(--green)"></div>
    </div>
    <div class="card">
      <div class="card-title">📸 Photo de profil</div>
      <div class="tx-sm tx-m" style="margin-bottom:12px">Insérée automatiquement dans le cadre portrait du template cv_vibe_modern.</div>
      <div class="flex gap-2 items-c" style="margin-bottom:12px">
        <input id="ph-name" placeholder="Aucune photo" readonly style="flex:1;font-size:12px">
        <button class="btn btn-secondary btn-sm" onclick="document.getElementById('ph-inp').click()">📂 Choisir</button>
        <input type="file" id="ph-inp" accept="image/*" style="display:none" onchange="loadPhoto(event)">
        <button class="btn btn-red btn-sm" id="ph-del-btn" onclick="removePhoto()" style="display:none">🗑</button>
      </div>
      <div id="ph-status" class="tx-sm" style="color:var(--green);margin-bottom:10px"></div>
      <div id="ph-preview-wrap" style="display:none;text-align:center">
        <img id="ph-preview" style="width:130px;height:130px;object-fit:cover;border-radius:50%;border:3px solid var(--accent);filter:grayscale(70%)">
        <div class="tx-sm tx-m mt1">Aperçu (niveaux de gris dans le CV)</div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">ℹ️ À propos</div>
      <div class="tx-sm tx-m" style="line-height:1.7">
        JobFinder — Le copilote de ta recherche d'emploi<br>
        Compatible Claude &amp; ChatGPT · Interface web locale<br>
        Données stockées dans le dossier <code style="color:var(--accent)">data/</code>
      </div>
    </div>
  </div>
</div>

<!-- Planning -->
<div id="page-planning" class="page">
  <div class="ph">
    <div class="ph-text"><h2>📅 Planning</h2><p>Calendrier de tous vos entretiens et étapes planifiées</p></div>
    <button class="btn btn-primary btn-sm" onclick="openAddStageModal()">+ Ajouter</button>
  </div>
  <!-- Filtres pills -->
  <div class="planning-filters">
    <button class="plan-pill active" data-plan="all"       onclick="setPlanFilter(this)">Tous</button>
    <button class="plan-pill pill-sent"      data-plan="sent"      onclick="setPlanFilter(this)">📨 Envoyée</button>
    <button class="plan-pill pill-wait"      data-plan="wait"      onclick="setPlanFilter(this)">⏳ En attente</button>
    <button class="plan-pill pill-interview" data-plan="interview" onclick="setPlanFilter(this)">🎤 Entretien</button>
    <input class="plan-search" id="plan-search" placeholder="🔍 Rechercher..." oninput="renderPlanning()">
  </div>
  <!-- Nav calendrier -->
  <div class="cal-nav">
    <button class="cal-nav-arrow" onclick="navCal(-1)">‹</button>
    <div class="cal-title-wrap">
      <div id="cal-title" class="cal-title"></div>
      <button class="cal-today-btn" onclick="navCal(0)">Aujourd'hui</button>
    </div>
    <button class="cal-nav-arrow" onclick="navCal(1)">›</button>
    <div class="cal-view-toggle">
      <button class="cal-view-btn active" data-v="7"  onclick="setCalView('7')">7 jours</button>
      <button class="cal-view-btn"        data-v="30" onclick="setCalView('30')">30 jours</button>
    </div>
  </div>
  <!-- Grille -->
  <div id="cal-grid"></div>
  <!-- Légende couleurs -->
  <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px;padding-top:12px;border-top:1px solid var(--border)">
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#2F5DA8;display:inline-block"></span>Candidature</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#3b82f6;display:inline-block"></span>RH</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#10b981;display:inline-block"></span>Téléphonique</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#4F7CAC;display:inline-block"></span>Technique</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#f59e0b;display:inline-block"></span>Test / Assessment</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#34d399;display:inline-block"></span>Offre reçue</span>
    <span style="font-size:11px;color:var(--text3);font-weight:600;display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:3px;background:#94a3b8;display:inline-block"></span>Autre</span>
  </div>
</div>

<!-- Templates CV -->
<div id="page-templates" class="page">
  <div class="ph">
    <div class="ph-text"><h2>🎨 Templates CV</h2><p>Vos modèles de CV — créez-en un via le wizard ou importez le vôtre</p></div>
    <button class="btn btn-primary btn-sm" onclick="openGenModal()">✨ Générer un template</button>
  </div>
  <div class="tpl-grid" id="tpl-grid">
    <div class="tpl-empty-state">
      <div style="font-size:48px">🎨</div>
      <div style="font-size:15px;font-weight:600;color:var(--text2)">Aucun template</div>
      <div style="font-size:13px">Cliquez sur "Générer un template" pour créer votre premier modèle</div>
      <button class="btn btn-primary" onclick="openGenModal()">✨ Générer maintenant</button>
    </div>
  </div>
</div>

<!-- Wizard génération template -->
<div id="tpl-gen-overlay">
  <div class="wiz-card">
    <div class="wiz-head">
      <div class="wiz-prog-wrap"><div class="wiz-prog-bar" id="wiz-prog" style="width:0%"></div></div>
      <div class="wiz-head-row">
        <span class="wiz-step-lbl" id="wiz-step-lbl"></span>
        <button class="modal-x" onclick="closeGenModal()">✕</button>
      </div>
    </div>
